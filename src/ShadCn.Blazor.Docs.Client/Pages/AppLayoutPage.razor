@page "/components/app-layout"

<PageTitle>App Layout - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">App Layout</h1>
        <p class="text-lg text-muted-foreground">
            A full-screen layout component with a sidebar and scrollable main content area.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple layout with a sidebar and scrollable body.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="flex h-[500px] border rounded-lg overflow-hidden">
                        <Sidebar>
                            <SidebarHeader>
                                <span class="font-semibold">Acme Inc</span>
                            </SidebarHeader>
                            <SidebarContent>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#" Active="true" Title="Dashboard">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        </Icon>
                                        <ChildContent>Dashboard</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#" Title="Users">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                        </Icon>
                                        <ChildContent>Users</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#" Title="Settings">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </Icon>
                                        <ChildContent>Settings</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarContent>
                            <SidebarFooter>
                                <div class="text-xs text-muted-foreground">v1.0.0</div>
                            </SidebarFooter>
                        </Sidebar>
                        <AppLayoutMain>
                            <AppLayoutBody Class="p-6">
                                <h2 class="text-xl font-semibold">Main Content</h2>
                                <p class="text-muted-foreground mt-2">Your page content goes here. The body is scrollable when content overflows.</p>
                                @for (int i = 0; i < 20; i++)
                                {
                                    <p class="mt-4 text-sm text-muted-foreground">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
                                }
                            </AppLayoutBody>
                        </AppLayoutMain>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Header" Description="A layout with a fixed header above the scrollable body.">
            <ComponentExample Code="@WithHeaderCode">
                <Preview>
                    <div class="flex h-[500px] border rounded-lg overflow-hidden">
                        <Sidebar>
                            <SidebarHeader>
                                <span class="font-semibold">Acme Inc</span>
                            </SidebarHeader>
                            <SidebarContent>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#" Active="true" Title="Dashboard">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        </Icon>
                                        <ChildContent>Dashboard</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#" Title="Users">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                        </Icon>
                                        <ChildContent>Users</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarContent>
                            <SidebarFooter>
                                <div class="text-xs text-muted-foreground">v1.0.0</div>
                            </SidebarFooter>
                        </Sidebar>
                        <AppLayoutMain>
                            <AppLayoutHeader Class="flex items-center px-6 py-3">
                                <span class="text-lg font-semibold">Dashboard</span>
                                <span class="ml-auto text-sm text-muted-foreground">Welcome back!</span>
                            </AppLayoutHeader>
                            <AppLayoutBody Class="p-6">
                                <p class="text-muted-foreground">The header stays fixed while the body scrolls.</p>
                                @for (int i = 0; i < 20; i++)
                                {
                                    <p class="mt-4 text-sm text-muted-foreground">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
                                }
                            </AppLayoutBody>
                        </AppLayoutMain>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Collapsible Sidebar" Description="Combine with a collapsible sidebar and a trigger in the header.">
            <ComponentExample Code="@CollapsibleCode">
                <Preview>
                    <div class="flex h-[500px] border rounded-lg overflow-hidden">
                        <Sidebar Collapsible="true" Collapsed="@collapsed" CollapsedChanged="v => collapsed = v">
                            <SidebarHeader>
                                <SidebarTrigger />
                                @if (!collapsed)
                                {
                                    <span class="font-semibold">Acme Inc</span>
                                }
                            </SidebarHeader>
                            <SidebarContent>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#" Active="true" Title="Dashboard">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        </Icon>
                                        <ChildContent>Dashboard</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#" Title="Users">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                        </Icon>
                                        <ChildContent>Users</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#" Title="Settings">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </Icon>
                                        <ChildContent>Settings</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarContent>
                        </Sidebar>
                        <AppLayoutMain>
                            <AppLayoutHeader Class="flex items-center px-6 py-3">
                                <span class="text-lg font-semibold">Dashboard</span>
                            </AppLayoutHeader>
                            <AppLayoutBody Class="p-6">
                                <p class="text-muted-foreground">Click the sidebar trigger to collapse or expand the sidebar.</p>
                                @for (int i = 0; i < 15; i++)
                                {
                                    <p class="mt-4 text-sm text-muted-foreground">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
                                }
                            </AppLayoutBody>
                        </AppLayoutMain>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool collapsed;

    private const string BasicCode = @"<AppLayout>
    <Sidebar>
        <SidebarHeader>
            <span class=""font-semibold"">Acme Inc</span>
        </SidebarHeader>
        <SidebarContent>
            <SidebarMenu>
                <SidebarMenuItem Href=""/"" Active=""true"">Dashboard</SidebarMenuItem>
                <SidebarMenuItem Href=""/users"">Users</SidebarMenuItem>
                <SidebarMenuItem Href=""/settings"">Settings</SidebarMenuItem>
            </SidebarMenu>
        </SidebarContent>
        <SidebarFooter>
            <div class=""text-xs text-muted-foreground"">v1.0.0</div>
        </SidebarFooter>
    </Sidebar>
    <AppLayoutMain>
        <AppLayoutBody Class=""p-6"">
            @Body
        </AppLayoutBody>
    </AppLayoutMain>
</AppLayout>";

    private const string WithHeaderCode = @"<AppLayout>
    <Sidebar>
        <SidebarHeader>
            <span class=""font-semibold"">Acme Inc</span>
        </SidebarHeader>
        <SidebarContent>
            <SidebarMenu>
                <SidebarMenuItem Href=""/"" Active=""true"">Dashboard</SidebarMenuItem>
                <SidebarMenuItem Href=""/users"">Users</SidebarMenuItem>
            </SidebarMenu>
        </SidebarContent>
        <SidebarFooter>
            <div class=""text-xs text-muted-foreground"">v1.0.0</div>
        </SidebarFooter>
    </Sidebar>
    <AppLayoutMain>
        <AppLayoutHeader Class=""flex items-center px-6 py-3"">
            <span class=""text-lg font-semibold"">Dashboard</span>
        </AppLayoutHeader>
        <AppLayoutBody Class=""p-6"">
            @Body
        </AppLayoutBody>
    </AppLayoutMain>
</AppLayout>";

    private const string CollapsibleCode = @"<AppLayout>
    <Sidebar Collapsible=""true"" Collapsed=""@@collapsed"" CollapsedChanged=""v => collapsed = v"">
        <SidebarHeader>
            <SidebarTrigger />
            @if (!collapsed)
            {
                <span class=""font-semibold"">Acme Inc</span>
            }
        </SidebarHeader>
        <SidebarContent>
            <SidebarMenu>
                <SidebarMenuItem Href=""/"" Active=""true"" Title=""Dashboard"">
                    <Icon>🏠</Icon>
                    <ChildContent>Dashboard</ChildContent>
                </SidebarMenuItem>
                <SidebarMenuItem Href=""/users"" Title=""Users"">
                    <Icon>👤</Icon>
                    <ChildContent>Users</ChildContent>
                </SidebarMenuItem>
            </SidebarMenu>
        </SidebarContent>
    </Sidebar>
    <AppLayoutMain>
        <AppLayoutHeader Class=""flex items-center px-6 py-3"">
            <span class=""text-lg font-semibold"">Dashboard</span>
        </AppLayoutHeader>
        <AppLayoutBody Class=""p-6"">
            @Body
        </AppLayoutBody>
    </AppLayoutMain>
</AppLayout>";
}
