@page "/components/dialog"

<PageTitle>Dialog Component - ShadCn.Blazor | Blazor UI</PageTitle>
<SeoHead 
    Description="Modal dialog component for Blazor. Display content in an overlay with accessible focus management."
    Keywords="Dialog, Blazor, UI component, ShadCn.Blazor, modal, overlay, popup, accessible"
    Canonical="https://www.shadcn-blazor.dev/components/dialog"
    OgTitle="Dialog Component - ShadCn.Blazor | Blazor UI" />

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Dialog</h1>
        <p class="text-lg text-muted-foreground">
            A modal dialog that interrupts the user with important content and expects a response.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple dialog with title, description, and actions.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <Dialog Open="@dialogOpen" OpenChanged="v => dialogOpen = v">
                        <DialogTrigger>
                            <Button>Open Dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Are you sure?</DialogTitle>
                                <DialogDescription>
                                    This action cannot be undone.
                                </DialogDescription>
                            </DialogHeader>
                            <DialogBody>
                                <p class="text-sm">
                                    Please confirm that you want to proceed with this action. If you have any doubts, it's best to cancel and review the information again.
                                </p>
                            </DialogBody>
                            <DialogFooter>
                                <Button Variant="ButtonVariant.Outline" @onclick="() => dialogOpen = false">Cancel</Button>
                                <Button @onclick="() => dialogOpen = false">Continue</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Form Dialog" Description="Dialog containing a form for user input. Use DialogBody to wrap the form content.">
            <ComponentExample Code="@FormCode">
                <Preview>
                    <Dialog Open="@formDialogOpen" OpenChanged="v => formDialogOpen = v">
                        <DialogTrigger>
                            <Button Variant="ButtonVariant.Outline">Edit Profile</Button>
                        </DialogTrigger>
                        <DialogContent Class="max-w-[425px]">
                            <DialogHeader>
                                <DialogTitle>Edit profile</DialogTitle>
                                <DialogDescription>
                                    Make changes to your profile here. Click save when you're done.
                                </DialogDescription>
                            </DialogHeader>
                            <DialogBody>
                                <div class="grid gap-4 py-4">
                                    <div class="grid grid-cols-4 items-center gap-4">
                                        <Label Class="text-right">Name</Label>
                                        <Input Class="col-span-3" Placeholder="Pedro Duarte" />
                                    </div>
                                    <div class="grid grid-cols-4 items-center gap-4">
                                        <Label Class="text-right">Username</Label>
                                    <Input Class="col-span-3" Placeholder="peduarte" />
                                    </div>
                                </div>
                            </DialogBody>
                            <DialogFooter>
                                <Button @onclick="() => formDialogOpen = false">Save changes</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Scrollable Content" Description="Use DialogBody to create a scrollable area for long content.">
            <ComponentExample Code="@ScrollableCode">
                <Preview>
                    <Dialog Open="@scrollableOpen" OpenChanged="v => scrollableOpen = v">
                        <DialogTrigger>
                            <Button Variant="ButtonVariant.Outline">Scrollable</Button>
                        </DialogTrigger>
                        <DialogContent Class="max-w-md">
                            <DialogHeader>
                                <DialogTitle>Terms of Service</DialogTitle>
                                <DialogDescription>Please read the following terms.</DialogDescription>
                            </DialogHeader>
                            <DialogBody>
                                @for (int i = 0; i < 20; i++)
                                {
                                    <p class="mb-4 text-sm">
                                        This is a paragraph of text that is repeated to demonstrate scrolling. 
                                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                                        Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                    </p>
                                }
                            </DialogBody>
                            <DialogFooter>
                                <Button @onclick="() => scrollableOpen = false">Accept</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Sizes" Description="Use the Size parameter to control the dialog width. Default is DialogSize.Default (max-w-lg).">
            <ComponentExample Code="@SizesCode">
                <Preview>
                    <div class="flex flex-wrap gap-4">
                        <Dialog Open="@sizeSmOpen" OpenChanged="v => sizeSmOpen = v">
                            <DialogTrigger>
                                <Button Variant="ButtonVariant.Outline">Small</Button>
                            </DialogTrigger>
                            <DialogContent Size="DialogSize.Sm">
                                <DialogHeader>
                                    <DialogTitle>Small Dialog</DialogTitle>
                                    <DialogDescription>This dialog uses DialogSize.Sm (max-w-sm).</DialogDescription>
                                </DialogHeader>
                                <DialogFooter>
                                    <Button @onclick="() => sizeSmOpen = false">Close</Button>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>

                        <Dialog Open="@sizeDefaultOpen" OpenChanged="v => sizeDefaultOpen = v">
                            <DialogTrigger>
                                <Button Variant="ButtonVariant.Outline">Default</Button>
                            </DialogTrigger>
                            <DialogContent Size="DialogSize.Default">
                                <DialogHeader>
                                    <DialogTitle>Default Dialog</DialogTitle>
                                    <DialogDescription>This dialog uses DialogSize.Default (max-w-lg).</DialogDescription>
                                </DialogHeader>
                                <DialogFooter>
                                    <Button @onclick="() => sizeDefaultOpen = false">Close</Button>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>

                        <Dialog Open="@sizeXlOpen" OpenChanged="v => sizeXlOpen = v">
                            <DialogTrigger>
                                <Button Variant="ButtonVariant.Outline">Extra Large</Button>
                            </DialogTrigger>
                            <DialogContent Size="DialogSize.Xl">
                                <DialogHeader>
                                    <DialogTitle>Extra Large Dialog</DialogTitle>
                                    <DialogDescription>This dialog uses DialogSize.Xl (max-w-xl).</DialogDescription>
                                </DialogHeader>
                                <DialogFooter>
                                    <Button @onclick="() => sizeXlOpen = false">Close</Button>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>

                        <Dialog Open="@sizeMax3xlOpen" OpenChanged="v => sizeMax3xlOpen = v">
                            <DialogTrigger>
                                <Button Variant="ButtonVariant.Outline">3XL</Button>
                            </DialogTrigger>
                            <DialogContent Size="DialogSize.Max3xl">
                                <DialogHeader>
                                    <DialogTitle>3XL Dialog</DialogTitle>
                                    <DialogDescription>This dialog uses DialogSize.Max3xl (max-w-3xl).</DialogDescription>
                                </DialogHeader>
                                <DialogFooter>
                                    <Button @onclick="() => sizeMax3xlOpen = false">Close</Button>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>

                        <Dialog Open="@sizeFullOpen" OpenChanged="v => sizeFullOpen = v">
                            <DialogTrigger>
                                <Button Variant="ButtonVariant.Outline">Fullscreen</Button>
                            </DialogTrigger>
                            <DialogContent Size="DialogSize.Full">
                                <DialogHeader>
                                    <DialogTitle>Fullscreen Dialog</DialogTitle>
                                    <DialogDescription>This dialog uses DialogSize.Full and covers the entire viewport.</DialogDescription>
                                </DialogHeader>
                                <DialogBody>
                                    Content goes here...
                                </DialogBody>
                                <DialogFooter>
                                    <Button @onclick="() => sizeFullOpen = false">Close</Button>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool dialogOpen;
    private bool formDialogOpen;
    private bool scrollableOpen;
    private bool sizeSmOpen;
    private bool sizeDefaultOpen;
    private bool sizeXlOpen;
    private bool sizeMax3xlOpen;
    private bool sizeFullOpen;

    private const string BasicCode = @"<Dialog @bind-Open=""dialogOpen"">
    <DialogTrigger>
        <Button>Open Dialog</Button>
    </DialogTrigger>
    <DialogContent>
        <DialogHeader>
            <DialogTitle>Are you sure?</DialogTitle>
            <DialogDescription>
                This action cannot be undone.
            </DialogDescription>
        </DialogHeader>
        <DialogFooter>
            <Button Variant=""ButtonVariant.Outline"">Cancel</Button>
            <Button>Continue</Button>
        </DialogFooter>
    </DialogContent>
</Dialog>";

    private const string FormCode = @"<Dialog @bind-Open=""formOpen"">
    <DialogTrigger>
        <Button Variant=""ButtonVariant.Outline"">Edit Profile</Button>
    </DialogTrigger>
    <DialogContent Class=""max-w-[425px]"">
        <DialogHeader>
            <DialogTitle>Edit profile</DialogTitle>
            <DialogDescription>
                Make changes to your profile here.
            </DialogDescription>
        </DialogHeader>
        <DialogBody>
            <div class=""grid gap-4 py-4"">
                <div class=""grid grid-cols-4 items-center gap-4"">
                    <Label Class=""text-right"">Name</Label>
                    <Input Class=""col-span-3"" />
                </div>
            </div>
        </DialogBody>
        <DialogFooter>
            <Button>Save changes</Button>
        </DialogFooter>
    </DialogContent>
</Dialog>";

    private const string ScrollableCode = @"<Dialog @bind-Open=""scrollableOpen"">
    <DialogTrigger>
        <Button Variant=""ButtonVariant.Outline"">Scrollable</Button>
    </DialogTrigger>
    <DialogContent Class=""max-w-md"">
        <DialogHeader>
            <DialogTitle>Terms of Service</DialogTitle>
            <DialogDescription>Please read the following terms.</DialogDescription>
        </DialogHeader>
        <DialogBody>
            @for (int i = 0; i < 20; i++)
            {
                <p class=""mb-4 text-sm"">
                    This is a paragraph of text that is repeated...
                </p>
            }
        </DialogBody>
        <DialogFooter>
            <Button>Accept</Button>
        </DialogFooter>
    </DialogContent>
</Dialog>";

    private const string SizesCode = @"@* Small *@
<DialogContent Size=""DialogSize.Sm"">...</DialogContent>

@* Default (max-w-lg) *@
<DialogContent Size=""DialogSize.Default"">...</DialogContent>

@* Extra Large *@
<DialogContent Size=""DialogSize.Xl"">...</DialogContent>

@* 3XL *@
<DialogContent Size=""DialogSize.Max3xl"">...</DialogContent>

@* Fullscreen *@
<DialogContent Size=""DialogSize.Full"">...</DialogContent>

@* Available sizes: Sm, Md, Lg, Xl, Max2xl, Max3xl, Max4xl, Max5xl, Max6xl, Max7xl, Full *@";
}
