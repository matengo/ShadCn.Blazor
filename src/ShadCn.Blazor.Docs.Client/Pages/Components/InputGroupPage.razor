@page "/components/input-group"

<PageTitle>Input Group Component - ShadCn.Blazor | Blazor UI</PageTitle>
<SeoHead
    Description="Input group component for combining inputs with icons, text, buttons, and other addons. Supports inline and block alignment."
    Keywords="InputGroup, Blazor, UI component, ShadCn.Blazor, input group, addon, form, CSS variables"
    Canonical="https://www.shadcn-blazor.dev/components/input-group"
    OgTitle="Input Group Component - ShadCn.Blazor | Blazor UI" />

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Input Group</h1>
        <p class="text-lg text-muted-foreground">
            Combine inputs with icons, text, buttons, and other addons.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <!-- Default -->
        <ExampleSection Title="Default" Description="A basic input group with a search icon addon.">
            <ComponentExample Code="@DefaultCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="Search..." />
                            <InputGroupAddon>
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                                </InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Inline Start -->
        <ExampleSection Title="Addon — Inline Start" Description="Use Align=&quot;InputGroupAlign.InlineStart&quot; (default) to position the addon before the input.">
            <ComponentExample Code="@InlineStartCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="Email address" Type="email" />
                            <InputGroupAddon Align="InputGroupAlign.InlineStart">
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                </InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Inline End -->
        <ExampleSection Title="Addon — Inline End" Description="Use Align=&quot;InputGroupAlign.InlineEnd&quot; to position the addon after the input.">
            <ComponentExample Code="@InlineEndCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="Enter amount" Type="number" />
                            <InputGroupAddon Align="InputGroupAlign.InlineEnd">
                                <InputGroupText>USD</InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Both Sides -->
        <ExampleSection Title="Addon — Both Sides" Description="Combine InlineStart and InlineEnd addons on the same input.">
            <ComponentExample Code="@BothSidesCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="https://example.com" />
                            <InputGroupAddon Align="InputGroupAlign.InlineStart">
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                                </InputGroupText>
                            </InputGroupAddon>
                            <InputGroupAddon Align="InputGroupAlign.InlineEnd">
                                <InputGroupButton>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                                    Copy
                                </InputGroupButton>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- With Button (password toggle) -->
        <ExampleSection Title="With Button" Description="Use InputGroupButton inside addons for interactive actions like password visibility toggle.">
            <ComponentExample Code="@ButtonCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="Enter password" Type="@(showPassword ? "text" : "password")" />
                            <InputGroupAddon Align="InputGroupAlign.InlineEnd">
                                <InputGroupButton Size="InputGroupButtonSize.IconXs" @onclick="TogglePassword">
                                    @if (showPassword)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" x2="23" y1="1" y2="23"/></svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    }
                                </InputGroupButton>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- With Text -->
        <ExampleSection Title="With Text" Description="Display static text like currency symbols or prefixes alongside the input.">
            <ComponentExample Code="@TextCode">
                <Preview>
                    <div class="max-w-sm space-y-4">
                        <InputGroup>
                            <InputGroupInput Placeholder="0.00" Type="number" />
                            <InputGroupAddon Align="InputGroupAlign.InlineStart">
                                <InputGroupText>$</InputGroupText>
                            </InputGroupAddon>
                            <InputGroupAddon Align="InputGroupAlign.InlineEnd">
                                <InputGroupText>.00</InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                        <InputGroup>
                            <InputGroupInput Placeholder="username" />
                            <InputGroupAddon Align="InputGroupAlign.InlineStart">
                                <InputGroupText>@@</InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- With Kbd -->
        <ExampleSection Title="With Kbd" Description="Show keyboard shortcuts inside the input group.">
            <ComponentExample Code="@KbdCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="Search documentation..." />
                            <InputGroupAddon Align="InputGroupAlign.InlineStart">
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                                </InputGroupText>
                            </InputGroupAddon>
                            <InputGroupAddon Align="InputGroupAlign.InlineEnd">
                                <kbd class="pointer-events-none inline-flex h-5 items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium text-muted-foreground">
                                    <span class="text-xs">⌘</span>K
                                </kbd>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Textarea with Block End -->
        <ExampleSection Title="Textarea — Block End" Description="Use InputGroupTextarea with block-end alignment for message inputs with action buttons.">
            <ComponentExample Code="@TextareaBlockEndCode">
                <Preview>
                    <div class="max-w-md">
                        <InputGroup>
                            <InputGroupTextarea Placeholder="Type your message..." Rows="3" />
                            <InputGroupAddon Align="InputGroupAlign.BlockEnd">
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                                </InputGroupText>
                                <InputGroupButton>Send</InputGroupButton>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Textarea with Block Start -->
        <ExampleSection Title="Textarea — Block Start" Description="Use block-start to position the addon above the textarea.">
            <ComponentExample Code="@TextareaBlockStartCode">
                <Preview>
                    <div class="max-w-md">
                        <InputGroup>
                            <InputGroupTextarea Placeholder="Write a comment..." Rows="3" />
                            <InputGroupAddon Align="InputGroupAlign.BlockStart">
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                </InputGroupText>
                                <span class="text-xs">Comment</span>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Disabled -->
        <ExampleSection Title="Disabled" Description="Disable the input to apply disabled styling to the entire group.">
            <ComponentExample Code="@DisabledCode">
                <Preview>
                    <div class="max-w-sm">
                        <InputGroup>
                            <InputGroupInput Placeholder="Disabled input" Disabled="true" />
                            <InputGroupAddon>
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                </InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <!-- Two-way Binding -->
        <ExampleSection Title="Two-way Binding" Description="InputGroupInput supports two-way data binding.">
            <ComponentExample Code="@BindingCode">
                <Preview>
                    <div class="max-w-sm space-y-4">
                        <InputGroup>
                            <InputGroupInput Placeholder="Type something..." @bind-Value="bindingValue" />
                            <InputGroupAddon Align="InputGroupAlign.InlineStart">
                                <InputGroupText>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.855z"/></svg>
                                </InputGroupText>
                            </InputGroupAddon>
                        </InputGroup>
                        <p class="text-sm text-muted-foreground">
                            Value: <strong>@bindingValue</strong>
                        </p>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool showPassword = false;
    private string bindingValue = "";

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private const string DefaultCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Search..."" />
    <InputGroupAddon>
        <InputGroupText>
            <!-- Search icon -->
            <svg>...</svg>
        </InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string InlineStartCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Email address"" Type=""email"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineStart"">
        <InputGroupText>
            <!-- Mail icon -->
            <svg>...</svg>
        </InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string InlineEndCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Enter amount"" Type=""number"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineEnd"">
        <InputGroupText>USD</InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string BothSidesCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""https://example.com"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineStart"">
        <InputGroupText>
            <!-- Globe icon -->
            <svg>...</svg>
        </InputGroupText>
    </InputGroupAddon>
    <InputGroupAddon Align=""InputGroupAlign.InlineEnd"">
        <InputGroupButton>
            <!-- Copy icon -->
            <svg>...</svg>
            Copy
        </InputGroupButton>
    </InputGroupAddon>
</InputGroup>";

    private const string ButtonCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Enter password""
                     Type=""@(showPassword ? ""text"" : ""password"")"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineEnd"">
        <InputGroupButton Size=""InputGroupButtonSize.IconXs""
                          @@onclick=""TogglePassword"">
            <!-- Eye / EyeOff icon -->
            <svg>...</svg>
        </InputGroupButton>
    </InputGroupAddon>
</InputGroup>

@code {
    private bool showPassword = false;

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }
}";

    private const string TextCode =
@"<!-- Currency input -->
<InputGroup>
    <InputGroupInput Placeholder=""0.00"" Type=""number"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineStart"">
        <InputGroupText>$</InputGroupText>
    </InputGroupAddon>
    <InputGroupAddon Align=""InputGroupAlign.InlineEnd"">
        <InputGroupText>.00</InputGroupText>
    </InputGroupAddon>
</InputGroup>

<!-- Username input -->
<InputGroup>
    <InputGroupInput Placeholder=""username"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineStart"">
        <InputGroupText>@@</InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string KbdCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Search documentation..."" />
    <InputGroupAddon Align=""InputGroupAlign.InlineStart"">
        <InputGroupText>
            <!-- Search icon -->
            <svg>...</svg>
        </InputGroupText>
    </InputGroupAddon>
    <InputGroupAddon Align=""InputGroupAlign.InlineEnd"">
        <kbd class=""pointer-events-none inline-flex h-5 ...""
             >⌘K</kbd>
    </InputGroupAddon>
</InputGroup>";

    private const string TextareaBlockEndCode =
@"<InputGroup>
    <InputGroupTextarea Placeholder=""Type your message..."" Rows=""3"" />
    <InputGroupAddon Align=""InputGroupAlign.BlockEnd"">
        <InputGroupText>
            <!-- Paperclip icon -->
            <svg>...</svg>
        </InputGroupText>
        <InputGroupButton>Send</InputGroupButton>
    </InputGroupAddon>
</InputGroup>";

    private const string TextareaBlockStartCode =
@"<InputGroup>
    <InputGroupTextarea Placeholder=""Write a comment..."" Rows=""3"" />
    <InputGroupAddon Align=""InputGroupAlign.BlockStart"">
        <InputGroupText>
            <!-- MessageSquare icon -->
            <svg>...</svg>
        </InputGroupText>
        <span class=""text-xs"">Comment</span>
    </InputGroupAddon>
</InputGroup>";

    private const string DisabledCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Disabled input"" Disabled=""true"" />
    <InputGroupAddon>
        <InputGroupText>
            <!-- Lock icon -->
            <svg>...</svg>
        </InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string BindingCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Type something...""
                     @@bind-Value=""bindingValue"" />
    <InputGroupAddon Align=""InputGroupAlign.InlineStart"">
        <InputGroupText>
            <!-- Edit icon -->
            <svg>...</svg>
        </InputGroupText>
    </InputGroupAddon>
</InputGroup>
<p>Value: <strong>@@bindingValue</strong></p>

@code {
    private string bindingValue = """";
}";
}
