@page "/components/avatar"

<PageTitle>Avatar Component - ShadCn.Blazor | Blazor UI</PageTitle>
<SeoHead 
    Description="Circular user profile images with fallback initials. Accessible avatar component for Blazor apps."
    Keywords="Avatar, Blazor, UI component, ShadCn.Blazor, profile image, user avatar, fallback, accessible"
    Canonical="https://www.shadcn-blazor.dev/components/avatar"
    OgTitle="Avatar Component - ShadCn.Blazor | Blazor UI" />

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Avatar</h1>
        <p class="text-lg text-muted-foreground">
            An image element with a fallback for representing the user.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="Avatar with image and fallback.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="flex gap-4">
                        <Avatar Src="https://github.com/shadcn.png" Alt="shadcn" />
                        <Avatar Fallback="CN" />
                        <Avatar Fallback="JD" />
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Sizes" Description="Customize avatar size with the Class parameter.">
            <ComponentExample Code="@SizesCode">
                <Preview>
                    <div class="flex items-center gap-4">
                        <Avatar Src="https://github.com/shadcn.png" Class="h-8 w-8" />
                        <Avatar Src="https://github.com/shadcn.png" Class="h-10 w-10" />
                        <Avatar Src="https://github.com/shadcn.png" Class="h-12 w-12" />
                        <Avatar Src="https://github.com/shadcn.png" Class="h-16 w-16" />
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Fallback" Description="Display initials when no image is provided.">
            <ComponentExample Code="@FallbackCode">
                <Preview>
                    <div class="flex gap-4">
                        <Avatar Fallback="AB" />
                        <Avatar Fallback="CD" />
                        <Avatar Fallback="EF" />
                        <Avatar Fallback="GH" />
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Fallback Color" Description="Set custom background colors for fallback avatars.">
            <ComponentExample Code="@FallbackColorCode">
                <Preview>
                    <div class="flex gap-4">
                        <Avatar Fallback="AB" FallbackColor="#e11d48" />
                        <Avatar Fallback="CD" FallbackColor="#2563eb" />
                        <Avatar Fallback="EF" FallbackColor="#16a34a" />
                        <Avatar Fallback="GH" FallbackColor="#9333ea" />
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private const string BasicCode = @"<Avatar Src=""https://github.com/shadcn.png"" Alt=""@shadcn"" />
<Avatar Fallback=""CN"" />";

    private const string SizesCode = @"<Avatar Src=""..."" Class=""h-8 w-8"" />
<Avatar Src=""..."" Class=""h-10 w-10"" />
<Avatar Src=""..."" Class=""h-12 w-12"" />
<Avatar Src=""..."" Class=""h-16 w-16"" />";

    private const string FallbackCode = @"<Avatar Fallback=""AB"" />
<Avatar Fallback=""CD"" />";

    private const string FallbackColorCode = @"<Avatar Fallback=""AB"" FallbackColor=""#e11d48"" />
<Avatar Fallback=""CD"" FallbackColor=""#2563eb"" />
<Avatar Fallback=""EF"" FallbackColor=""#16a34a"" />
<Avatar Fallback=""GH"" FallbackColor=""#9333ea"" />";
}
