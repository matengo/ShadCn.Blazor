@page "/components/sheet"

<PageTitle>Sheet Component - ShadCn.Blazor | Blazor UI</PageTitle>
<SeoHead 
    Description="Slide-out panel from screen edges. Build side panels, mobile menus, and detail views in Blazor."
    Keywords="Sheet, Blazor, UI component, ShadCn.Blazor, slide-out, side panel, mobile menu, drawer"
    Canonical="https://www.shadcn-blazor.dev/components/sheet"
    OgTitle="Sheet Component - ShadCn.Blazor | Blazor UI" />

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Sheet</h1>
        <p class="text-lg text-muted-foreground">
            A panel that slides out from the edge of the screen. Useful for navigation, details, or editing forms.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple sheet that slides in from the right.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <Sheet @bind-Open="_basicOpen">
                        <SheetTrigger>
                            <Button>Open Sheet</Button>
                        </SheetTrigger>
                        <SheetContent Side="SheetSide.Right">
                            <SheetHeader>
                                <SheetTitle>Edit profile</SheetTitle>
                                <SheetDescription>
                                    Make changes to your profile here. Click save when you're done.
                                </SheetDescription>
                            </SheetHeader>
                            <SheetBody>
                                <div class="grid gap-4 py-4">
                                    <div class="grid grid-cols-4 items-center gap-4">
                                        <Label Class="text-right">Name</Label>
                                        <Input Class="col-span-3" Placeholder="Pedro Duarte" />
                                    </div>
                                    <div class="grid grid-cols-4 items-center gap-4">
                                        <Label Class="text-right">Username</Label>
                                        <Input Class="col-span-3" Placeholder="peduarte" />
                                    </div>
                                </div>
                            </SheetBody>
                            <SheetFooter>
                                <SheetClose>
                                    <Button Variant="ButtonVariant.Outline">Cancel</Button>
                                </SheetClose>
                                <Button @onclick="() => _basicOpen = false">Save changes</Button>
                            </SheetFooter>
                        </SheetContent>
                    </Sheet>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Side" Description="Use the Side property to control the direction the Sheet slides in from.">
            <ComponentExample Code="@SidesCode">
                <Preview>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var side in Enum.GetValues<SheetSide>())
                        {
                            <Sheet @bind-Open="_sideStates[side]">
                                <SheetTrigger>
                                    <Button Variant="ButtonVariant.Outline">@side</Button>
                                </SheetTrigger>
                                <SheetContent Side="@side">
                                    <SheetHeader>
                                        <SheetTitle>@side Sheet</SheetTitle>
                                        <SheetDescription>
                                            This sheet slides in from the @side.ToString().ToLower().
                                        </SheetDescription>
                                    </SheetHeader>
                                    <SheetBody>
                                        <p class="text-sm text-muted-foreground">Content goes here.</p>
                                    </SheetBody>
                                    <SheetFooter>
                                        <SheetClose>
                                            <Button>Close</Button>
                                        </SheetClose>
                                    </SheetFooter>
                                </SheetContent>
                            </Sheet>
                        }
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
        <ExampleSection Title="Scrollable Content" Description="Use SheetBody to create a scrollable area for long content. The footer stays at the bottom.">
            <ComponentExample Code="@ScrollableCode">
                <Preview>
                    <Sheet @bind-Open="_scrollableOpen">
                        <SheetTrigger>
                            <Button Variant="ButtonVariant.Outline">Scrollable Sheet</Button>
                        </SheetTrigger>
                        <SheetContent Side="SheetSide.Right">
                            <SheetHeader>
                                <SheetTitle>Terms of Service</SheetTitle>
                                <SheetDescription>Please read the following terms carefully.</SheetDescription>
                            </SheetHeader>
                            <SheetBody>
                                @for (int i = 0; i < 30; i++)
                                {
                                    <p class="mb-4 text-sm">
                                        This is a paragraph of text that is repeated to demonstrate scrolling.
                                        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                                        Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                    </p>
                                }
                            </SheetBody>
                            <SheetFooter>
                                <Button @onclick="() => _scrollableOpen = false">Accept</Button>
                            </SheetFooter>
                        </SheetContent>
                    </Sheet>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool _basicOpen;
    private bool _scrollableOpen;
    private Dictionary<SheetSide, bool> _sideStates = Enum.GetValues<SheetSide>().ToDictionary(s => s, _ => false);

    private const string BasicCode = @"<Sheet @bind-Open=""sheetOpen"">
    <SheetTrigger>
        <Button>Open Sheet</Button>
    </SheetTrigger>
    <SheetContent Side=""SheetSide.Right"">
        <SheetHeader>
            <SheetTitle>Edit profile</SheetTitle>
            <SheetDescription>
                Make changes to your profile here.
            </SheetDescription>
        </SheetHeader>
        <SheetBody>
            <div class=""grid gap-4 py-4"">
                <div class=""grid grid-cols-4 items-center gap-4"">
                    <Label Class=""text-right"">Name</Label>
                    <Input Class=""col-span-3"" Placeholder=""Pedro Duarte"" />
                </div>
            </div>
        </SheetBody>
        <SheetFooter>
            <SheetClose>
                <Button Variant=""ButtonVariant.Outline"">Cancel</Button>
            </SheetClose>
            <Button>Save changes</Button>
        </SheetFooter>
    </SheetContent>
</Sheet>";

    private const string SidesCode = @"@foreach (var side in Enum.GetValues<SheetSide>())
{
    <Sheet @bind-Open=""sideStates[side]"">
        <SheetTrigger>
            <Button Variant=""ButtonVariant.Outline"">@side</Button>
        </SheetTrigger>
        <SheetContent Side=""@side"">
            <SheetHeader>
                <SheetTitle>@side Sheet</SheetTitle>
                <SheetDescription>
                    This sheet slides in from the @side.
                </SheetDescription>
            </SheetHeader>
            <SheetBody>
                <p>Content goes here.</p>
            </SheetBody>
            <SheetFooter>
                <SheetClose>
                    <Button>Close</Button>
                </SheetClose>
            </SheetFooter>
        </SheetContent>
    </Sheet>
}";

    private const string ScrollableCode = @"<Sheet @bind-Open=""scrollableOpen"">
    <SheetTrigger>
        <Button Variant=""ButtonVariant.Outline"">Scrollable Sheet</Button>
    </SheetTrigger>
    <SheetContent Side=""SheetSide.Right"">
        <SheetHeader>
            <SheetTitle>Terms of Service</SheetTitle>
            <SheetDescription>Please read the following terms.</SheetDescription>
        </SheetHeader>
        <SheetBody>
            @for (int i = 0; i < 30; i++)
            {
                <p class=""mb-4 text-sm"">
                    Long content that will scroll...
                </p>
            }
        </SheetBody>
        <SheetFooter>
            <Button>Accept</Button>
        </SheetFooter>
    </SheetContent>
</Sheet>";
}
