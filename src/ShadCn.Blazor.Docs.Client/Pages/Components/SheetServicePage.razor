@page "/components/sheet-service"
@using ShadCn.Blazor.Components.Sheet
@inject ISheetService SheetService

<PageTitle>Sheet Service - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Sheet Service</h1>
        <p class="text-lg text-muted-foreground">
            A service to programmatically open sheets with strongly-typed results.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <section class="space-y-4">
            <h2 class="text-2xl font-semibold">Usage</h2>
            <p>
                Inject <code>ISheetService</code> and use <code>ShowAsync&lt;TComponent, TResult, TInput&gt;</code>.
            </p>

            <div class="p-6 border rounded-lg bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col gap-4">
                    <p>Current Result: <strong>@(_lastResult ?? "None")</strong></p>

                    <div class="flex gap-4">
                        <Button OnClick="OpenSheet">Open Edit Profile Sheet</Button>
                    </div>
                </div>
            </div>
        </section>

        <section class="space-y-4">
            <h2 class="text-2xl font-semibold">Sides</h2>
            <p>
                Control which edge the sheet slides in from using <code>SheetOptions.Side</code>.
            </p>

            <div class="p-6 border rounded-lg bg-card text-card-foreground shadow-sm">
                <div class="flex flex-wrap gap-2">
                    @foreach (var side in Enum.GetValues<SheetSide>())
                    {
                        <Button Variant="ButtonVariant.Outline" OnClick="@(() => OpenSide(side))">
                            @side
                        </Button>
                    }
                </div>
            </div>
        </section>

        <section class="space-y-4">
            <h2 class="text-2xl font-semibold">Stacked Sheets</h2>
            <p>
                Sheets can be opened from within other sheets. Each new sheet stacks on top with proper z-index management.
                Sheets alternate sides to visually distinguish the layers.
            </p>

            <div class="p-6 border rounded-lg bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col gap-4">
                    <p>Result: <strong>@(_stackedResult ?? "None")</strong></p>
                    <div class="flex gap-4">
                        <Button OnClick="OpenStackedSheet">Open Stacked Sheets</Button>
                    </div>
                </div>
            </div>

            <div class="rounded-md bg-muted p-4">
<pre class="overflow-x-auto"><code>// The sheet component can inject ISheetService and open new sheets:
@@inject ISheetService SheetService

&lt;SheetHeader&gt;
    &lt;SheetTitle&gt;Sheet Level @@Data.Level&lt;/SheetTitle&gt;
&lt;/SheetHeader&gt;
&lt;SheetBody&gt;
    &lt;p&gt;Sheet content...&lt;/p&gt;
&lt;/SheetBody&gt;
&lt;SheetFooter&gt;
    &lt;Button OnClick="OpenNested"&gt;Open Next Sheet&lt;/Button&gt;
&lt;/SheetFooter&gt;

@@code {
    [Parameter] public NestedDialogModel Data { get; set; } = new();
    [CascadingParameter] public SheetContext Sheet { get; set; } = default!;
    @@inject ISheetService SheetService

    private async Task OpenNested()
    {
        var nextSide = Data.Level % 2 == 0 ? SheetSide.Left : SheetSide.Right;
        var input = new NestedDialogModel { Level = Data.Level + 1 };
        var result = await SheetService
            .ShowAsync&lt;NestedSheetContent, string, NestedDialogModel&gt;(
                input, new SheetOptions { Side = nextSide });
    }
}</code></pre>
            </div>
        </section>

        <section class="space-y-4">
            <h2 class="text-2xl font-semibold">Code</h2>
            <div class="rounded-md bg-muted p-4">
<pre class="overflow-x-auto"><code>@@inject ISheetService SheetService

@@code {
    private async Task OpenSheet()
    {
        var input = new EditProfileModel { Name = "John Doe", Username = "johndoe" };

        var result = await SheetService.ShowAsync&lt;EditProfileSheet, EditProfileModel, EditProfileModel&gt;(
            input,
            new SheetOptions { Side = SheetSide.Right }
        );

        if (result != null)
        {
            Console.WriteLine($"Updated: {result.Name}");
        }
    }
}</code></pre>
            </div>
        </section>
    </div>
</div>

@code {
    private string? _lastResult;
    private string? _stackedResult;

    private async Task OpenSheet()
    {
        var model = new EditProfileModel { Name = "John Doe", Username = "@@johndoe" };

        var result = await SheetService.ShowAsync<EditProfileSheet, EditProfileModel, EditProfileModel>(
            model,
            new SheetOptions { Side = SheetSide.Right }
        );

        if (result != null)
        {
            _lastResult = $"Saved: {result.Name} ({result.Username})";
        }
        else
        {
            _lastResult = "Cancelled";
        }
    }

    private async Task OpenSide(SheetSide side)
    {
        var model = new EditProfileModel();
        var options = new SheetOptions { Side = side };

        var result = await SheetService.ShowAsync<EditProfileSheet, EditProfileModel, EditProfileModel>(model, options);

        if (result != null)
        {
            _lastResult = $"Saved from {side}: {result.Name} ({result.Username})";
        }
        else
        {
            _lastResult = $"{side} sheet dismissed";
        }
    }

    private async Task OpenStackedSheet()
    {
        var input = new NestedDialogModel { Level = 1 };
        var result = await SheetService.ShowAsync<NestedSheetContent, string, NestedDialogModel>(
            input,
            new SheetOptions { Side = SheetSide.Right });
        _stackedResult = result ?? "Dismissed";
    }
}
