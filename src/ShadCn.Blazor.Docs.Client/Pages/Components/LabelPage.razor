@page "/components/label"

<PageTitle>Label - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Label</h1>
        <p class="text-lg text-muted-foreground">
            Renders an accessible label associated with controls.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A basic label for form controls.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="w-full max-w-sm space-y-4">
                        <div class="space-y-2">
                            <Label For="email">Email</Label>
                            <Input id="email" type="email" Placeholder="Enter your email" />
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Checkbox" Description="Label with checkbox.">
            <ComponentExample Code="@WithCheckboxCode">
                <Preview>
                    <div class="flex items-center space-x-2">
                        <Checkbox Checked="@accepted" CheckedChanged="v => accepted = v" />
                        <Label>Accept terms and conditions</Label>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool accepted = false;

    private const string BasicCode = @"<Label For=""email"">Email</Label>
<Input id=""email"" type=""email"" Placeholder=""Enter your email"" />";

    private const string WithCheckboxCode = @"<div class=""flex items-center space-x-2"">
    <Checkbox @bind-Checked=""accepted"" />
    <Label>Accept terms and conditions</Label>
</div>";
}
