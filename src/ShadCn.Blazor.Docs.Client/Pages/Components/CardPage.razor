@page "/components/card"

<PageTitle>Card - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Card</h1>
        <p class="text-lg text-muted-foreground">
            Displays a card with header, content, and footer.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Default" Description="Cards are composed of header, content, and footer slots.">
            <ComponentExample Code="@DefaultCode">
                <Preview>
                    <Card Class="max-w-sm">
                        <CardHeader>
                            <CardTitle>Card Title</CardTitle>
                            <CardDescription>Card Description</CardDescription>
                        </CardHeader>
                        <CardContent>
                            <p>Card Content</p>
                        </CardContent>
                        <CardFooter>
                            <Button>Action</Button>
                        </CardFooter>
                    </Card>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Example: Notifications" Description="Use cards to group related content.">
            <ComponentExample Code="@NotificationsCode">
                <Preview>
                    <Card Class="max-w-md">
                        <CardHeader>
                            <CardTitle>Notifications</CardTitle>
                            <CardDescription>You have 3 unread messages.</CardDescription>
                        </CardHeader>
                        <CardContent>
                            <div class="space-y-4">
                                <div class="flex items-start gap-4">
                                    <div class="h-2 w-2 rounded-full bg-primary mt-2"></div>
                                    <div class="space-y-1">
                                        <p class="text-sm font-medium">Your call has been confirmed.</p>
                                        <p class="text-sm text-muted-foreground">1 hour ago</p>
                                    </div>
                                </div>
                                <div class="flex items-start gap-4">
                                    <div class="h-2 w-2 rounded-full bg-primary mt-2"></div>
                                    <div class="space-y-1">
                                        <p class="text-sm font-medium">You have a new message!</p>
                                        <p class="text-sm text-muted-foreground">2 hours ago</p>
                                    </div>
                                </div>
                            </div>
                        </CardContent>
                        <CardFooter>
                            <Button Class="w-full">Mark all as read</Button>
                        </CardFooter>
                    </Card>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private const string DefaultCode = @"<Card Class=""max-w-sm"">
    <CardHeader>
        <CardTitle>Card Title</CardTitle>
        <CardDescription>Card Description</CardDescription>
    </CardHeader>
    <CardContent>
        <p>Card Content</p>
    </CardContent>
    <CardFooter>
        <Button>Action</Button>
    </CardFooter>
</Card>";

    private const string NotificationsCode = @"<Card Class=""max-w-md"">
    <CardHeader>
        <CardTitle>Notifications</CardTitle>
        <CardDescription>You have 3 unread messages.</CardDescription>
    </CardHeader>
    <CardContent>
        <div class=""space-y-4"">
            <div class=""flex items-start gap-4"">
                <div class=""h-2 w-2 rounded-full bg-primary mt-2""></div>
                <div class=""space-y-1"">
                    <p class=""text-sm font-medium"">Your call has been confirmed.</p>
                    <p class=""text-sm text-muted-foreground"">1 hour ago</p>
                </div>
            </div>
            <div class=""flex items-start gap-4"">
                <div class=""h-2 w-2 rounded-full bg-primary mt-2""></div>
                <div class=""space-y-1"">
                    <p class=""text-sm font-medium"">You have a new message!</p>
                    <p class=""text-sm text-muted-foreground"">2 hours ago</p>
                </div>
            </div>
        </div>
    </CardContent>
    <CardFooter>
        <Button Class=""w-full"">Mark all as read</Button>
    </CardFooter>
</Card>";
}
