@page "/components/textarea"

<PageTitle>Textarea - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Textarea</h1>
        <p class="text-lg text-muted-foreground">
            Displays a form textarea or a component that looks like a textarea.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A basic textarea with placeholder.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="w-full max-w-sm">
                        <Textarea Placeholder="Type your message here..." />
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Label" Description="Textarea with a label.">
            <ComponentExample Code="@WithLabelCode">
                <Preview>
                    <div class="w-full max-w-sm space-y-2">
                        <Label For="message">Your Message</Label>
                        <Textarea id="message" Placeholder="Enter your message..." Value="@message" ValueChanged="v => message = v" />
                        <p class="text-sm text-muted-foreground">Characters: @message.Length</p>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Disabled" Description="Disabled textarea.">
            <ComponentExample Code="@DisabledCode">
                <Preview>
                    <div class="w-full max-w-sm">
                        <Textarea Placeholder="This textarea is disabled..." Disabled="true" />
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private string message = "";

    private const string BasicCode = @"<Textarea Placeholder=""Type your message here..."" />";

    private const string WithLabelCode = @"<Label For=""message"">Your Message</Label>
<Textarea id=""message"" Placeholder=""Enter your message..."" @bind-Value=""message"" />

@code {
    private string message = """";
}";

    private const string DisabledCode = @"<Textarea Placeholder=""This is disabled..."" Disabled=""true"" />";
}
