    private const string VariantsCode = @"<Item Variant=""ItemVariant.Default"">...</Item>
<Item Variant=""ItemVariant.Ghost"">...</Item>
<Item Variant=""ItemVariant.Muted"">...</Item>";

    private const string GroupCode = @"<ItemGroup>
    <Item>
        <ItemMedia Variant=""ItemMediaVariant.Icon"">
