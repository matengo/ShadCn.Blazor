@page "/components/item"

<PageTitle>Item - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Item</h1>
        <p class="text-lg text-muted-foreground">
            A flexible container for displaying content with media, title, description, and actions.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple item with title and description.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="max-w-md">
                        <Item>
                            <ItemContent>
                                <ItemTitle>Notifications</ItemTitle>
                                <ItemDescription>Manage your notification preferences.</ItemDescription>
                            </ItemContent>
                        </Item>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Icon" Description="Use ItemMedia with the Icon variant to display an icon.">
            <ComponentExample Code="@IconCode">
                <Preview>
                    <div class="max-w-md">
                        <Item>
                            <ItemMedia Variant="ItemMediaVariant.Icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                            </ItemMedia>
                            <ItemContent>
                                <ItemTitle>Notifications</ItemTitle>
                                <ItemDescription>You have 3 unread messages.</ItemDescription>
                            </ItemContent>
                        </Item>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Actions" Description="Add actions like buttons to the right side.">
            <ComponentExample Code="@ActionsCode">
                <Preview>
                    <div class="max-w-lg">
                        <Item>
                            <ItemMedia Variant="ItemMediaVariant.Icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                            </ItemMedia>
                            <ItemContent>
                                <ItemTitle>Settings</ItemTitle>
                                <ItemDescription>Configure your application settings.</ItemDescription>
                            </ItemContent>
                            <ItemActions>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Edit</Button>
                            </ItemActions>
                        </Item>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Variants" Description="Use the Variant parameter to change the visual style.">
            <ComponentExample Code="@VariantsCode">
                <Preview>
                    <div class="max-w-md space-y-4">
                        <Item Variant="ItemVariant.Default">
                            <ItemContent>
                                <ItemTitle>Default</ItemTitle>
                                <ItemDescription>With a visible border.</ItemDescription>
                            </ItemContent>
                        </Item>
                        <Item Variant="ItemVariant.Ghost">
                            <ItemContent>
                                <ItemTitle>Ghost</ItemTitle>
                                <ItemDescription>No border, transparent background.</ItemDescription>
                            </ItemContent>
                        </Item>
                        <Item Variant="ItemVariant.Muted">
                            <ItemContent>
                                <ItemTitle>Muted</ItemTitle>
                                <ItemDescription>Subtle muted background.</ItemDescription>
                            </ItemContent>
                        </Item>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Group" Description="Use ItemGroup and ItemSeparator to group related items.">
            <ComponentExample Code="@GroupCode">
                <Preview>
                    <div class="max-w-md rounded-lg border">
                        <ItemGroup>
                            <Item>
                                <ItemMedia Variant="ItemMediaVariant.Icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                </ItemMedia>
                                <ItemContent>
                                    <ItemTitle>Profile</ItemTitle>
                                    <ItemDescription>Manage your profile settings.</ItemDescription>
                                </ItemContent>
                            </Item>
                            <ItemSeparator />
                            <Item>
                                <ItemMedia Variant="ItemMediaVariant.Icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                </ItemMedia>
                                <ItemContent>
                                    <ItemTitle>Security</ItemTitle>
                                    <ItemDescription>Update your password and security settings.</ItemDescription>
                                </ItemContent>
                            </Item>
                            <ItemSeparator />
                            <Item>
                                <ItemMedia Variant="ItemMediaVariant.Icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                                </ItemMedia>
                                <ItemContent>
                                    <ItemTitle>Notifications</ItemTitle>
                                    <ItemDescription>Configure notification preferences.</ItemDescription>
                                </ItemContent>
                            </Item>
                        </ItemGroup>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Sizes" Description="Use the Size parameter to control item density.">
            <ComponentExample Code="@SizesCode">
                <Preview>
                    <div class="max-w-md space-y-4">
                        <Item Size="ItemSize.Default">
                            <ItemContent>
                                <ItemTitle>Default size</ItemTitle>
                                <ItemDescription>Standard padding and gaps.</ItemDescription>
                            </ItemContent>
                        </Item>
                        <Item Size="ItemSize.Sm">
                            <ItemContent>
                                <ItemTitle>Small size</ItemTitle>
                                <ItemDescription>Compact padding and gaps.</ItemDescription>
                            </ItemContent>
                        </Item>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private const string BasicCode = @"<Item>
    <ItemContent>
        <ItemTitle>Notifications</ItemTitle>
        <ItemDescription>Manage your notification preferences.</ItemDescription>
    </ItemContent>
</Item>";

    private const string IconCode = @"<Item>
    <ItemMedia Variant=""ItemMediaVariant.Icon"">
        <BellIcon />
    </ItemMedia>
    <ItemContent>
        <ItemTitle>Notifications</ItemTitle>
        <ItemDescription>You have 3 unread messages.</ItemDescription>
    </ItemContent>
</Item>";

    private const string ActionsCode = @"<Item>
    <ItemMedia Variant=""ItemMediaVariant.Icon"">
        <SettingsIcon />
    </ItemMedia>
    <ItemContent>
        <ItemTitle>Settings</ItemTitle>
        <ItemDescription>Configure your application settings.</ItemDescription>
    </ItemContent>
    <ItemActions>
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"">Edit</Button>
    </ItemActions>
