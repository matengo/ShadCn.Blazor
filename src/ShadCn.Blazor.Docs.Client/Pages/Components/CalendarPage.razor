@page "/components/calendar"
@using ShadCn.Blazor.Components

<PageTitle>Calendar Component - ShadCn.Blazor | Blazor UI</PageTitle>
<SeoHead 
    Description="Interactive date selection calendar component for Blazor. Supports single date picking."
    Keywords="Calendar, Blazor, UI component, ShadCn.Blazor, date picker, date selection, interactive"
    Canonical="https://www.shadcn-blazor.dev/components/calendar"
    OgTitle="Calendar Component - ShadCn.Blazor | Blazor UI" />

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Calendar</h1>
        <p class="text-lg text-muted-foreground">
            A date field component that allows users to select a date from a calendar view.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple calendar for date selection.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="flex gap-8 flex-wrap">
                        <div class="space-y-2">
                            <Calendar Class="rounded-lg border" SelectedDate="@selectedDate" SelectedDateChanged="v => selectedDate = v" />
                            @if (selectedDate.HasValue)
                            {
                                <p class="mt-4 text-sm text-muted-foreground">
                                    Selected: @selectedDate.Value.ToString("dddd, MMMM d, yyyy")
                                </p>
                            }
                        </div>
                        
                    </div>

                    
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Preselected Date" Description="Calendar with an initial date selected.">
            <ComponentExample Code="@PreselectedCode">
                <Preview>
                    <div class="flex gap-8 flex-wrap">
                        <div class="space-y-2">
                            <Calendar Class="rounded-lg border" SelectedDate="@preselectedDate" SelectedDateChanged="v => preselectedDate = v" />
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Date Range Constraints" Description="Limit selectable dates with min and max values.">
            <ComponentExample Code="@ConstrainedCode">
                <Preview>
                    <div class="flex gap-8 flex-wrap">
                        <div class="space-y-2">
                            <Calendar Class="rounded-lg border"
                                      SelectedDate="@constrainedDate"
                                      SelectedDateChanged="v => constrainedDate = v"
                                      MinDate="@DateTime.Today"
                                      MaxDate="@DateTime.Today.AddDays(30)" />
                            <p class="text-sm text-muted-foreground">
                                Only dates from today to 30 days ahead can be selected.
                            </p>
                        </div>
                    </div>
                    
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="First Day of Week" Description="Configure which day the week starts on.">
            <ComponentExample Code="@FirstDayCode">
                <Preview>
                    <div class="flex gap-8 flex-wrap">
                        <div class="space-y-2">
                            <p class="text-sm font-medium">Monday (default)</p>
                            <Calendar Class="rounded-lg border" FirstDayOfWeek="DayOfWeek.Monday" />
                        </div>
                        <div class="space-y-2">
                            <p class="text-sm font-medium">Sunday</p>
                            <Calendar Class="rounded-lg border" FirstDayOfWeek="DayOfWeek.Sunday" />
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private DateTime? selectedDate;
    private DateTime? preselectedDate = DateTime.Today;
    private DateTime? constrainedDate;

    private const string BasicCode = @"<Calendar @bind-SelectedDate=""selectedDate"" />

@code {
    private DateTime? selectedDate;
}";

    private const string PreselectedCode = @"<Calendar @bind-SelectedDate=""selectedDate"" />

@code {
    private DateTime? selectedDate = DateTime.Today;
}";

    private const string ConstrainedCode = @"<Calendar @bind-SelectedDate=""selectedDate""
          MinDate=""@DateTime.Today""
          MaxDate=""@DateTime.Today.AddDays(30)"" />

@code {
    private DateTime? selectedDate;
}";

    private const string FirstDayCode = @"@* Start week on Monday (European style) *@
<Calendar FirstDayOfWeek=""DayOfWeek.Monday"" />

@* Start week on Sunday (US style) *@
<Calendar FirstDayOfWeek=""DayOfWeek.Sunday"" />";
}
