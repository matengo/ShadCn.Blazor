@page "/components/dialog"
@using ShadCn.Blazor.Docs.Shared

<PageTitle>Dialog - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Dialog</h1>
        <p class="text-lg text-muted-foreground">
            A modal dialog that interrupts the user with important content and expects a response.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple dialog with title, description, and actions.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <Dialog Open="@dialogOpen" OpenChanged="v => dialogOpen = v">
                        <DialogTrigger>
                            <Button>Open Dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Are you sure?</DialogTitle>
                                <DialogDescription>
                                    This action cannot be undone. This will permanently delete your account and remove your data from our servers.
                                </DialogDescription>
                            </DialogHeader>
                            <DialogFooter>
                                <Button Variant="ButtonVariant.Outline" @onclick="() => dialogOpen = false">Cancel</Button>
                                <Button @onclick="() => dialogOpen = false">Continue</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Form Dialog" Description="Dialog containing a form for user input.">
            <ComponentExample Code="@FormCode">
                <Preview>
                    <Dialog Open="@formDialogOpen" OpenChanged="v => formDialogOpen = v">
                        <DialogTrigger>
                            <Button Variant="ButtonVariant.Outline">Edit Profile</Button>
                        </DialogTrigger>
                        <DialogContent Class="max-w-[425px]">
                            <DialogHeader>
                                <DialogTitle>Edit profile</DialogTitle>
                                <DialogDescription>
                                    Make changes to your profile here. Click save when you're done.
                                </DialogDescription>
                            </DialogHeader>
                            <div class="grid gap-4 py-4">
                                <div class="grid grid-cols-4 items-center gap-4">
                                    <Label Class="text-right">Name</Label>
                                    <Input Class="col-span-3" Placeholder="Pedro Duarte" />
                                </div>
                                <div class="grid grid-cols-4 items-center gap-4">
                                    <Label Class="text-right">Username</Label>
                                <Input Class="col-span-3" Placeholder="peduarte" />
                                </div>
                            </div>
                            <DialogFooter>
                                <Button @onclick="() => formDialogOpen = false">Save changes</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool dialogOpen;
    private bool formDialogOpen;

    private const string BasicCode = @"<Dialog @bind-Open=""dialogOpen"">
    <DialogTrigger>
        <Button>Open Dialog</Button>
    </DialogTrigger>
    <DialogContent>
        <DialogHeader>
            <DialogTitle>Are you sure?</DialogTitle>
            <DialogDescription>
                This action cannot be undone.
            </DialogDescription>
        </DialogHeader>
        <DialogFooter>
            <Button Variant=""ButtonVariant.Outline"">Cancel</Button>
            <Button>Continue</Button>
        </DialogFooter>
    </DialogContent>
</Dialog>";

    private const string FormCode = @"<Dialog @bind-Open=""formOpen"">
    <DialogTrigger>
        <Button Variant=""ButtonVariant.Outline"">Edit Profile</Button>
    </DialogTrigger>
    <DialogContent Class=""max-w-[425px]"">
        <DialogHeader>
            <DialogTitle>Edit profile</DialogTitle>
            <DialogDescription>
                Make changes to your profile here.
            </DialogDescription>
        </DialogHeader>
        <div class=""grid gap-4 py-4"">
            <div class=""grid grid-cols-4 items-center gap-4"">
                <Label Class=""text-right"">Name</Label>
                <Input Class=""col-span-3"" />
            </div>
        </div>
        <DialogFooter>
            <Button>Save changes</Button>
        </DialogFooter>
    </DialogContent>
</Dialog>";
}
