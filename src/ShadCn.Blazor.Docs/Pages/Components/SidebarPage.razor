@page "/components/sidebar"
@using ShadCn.Blazor.Docs.Shared

<PageTitle>Sidebar - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Sidebar</h1>
        <p class="text-lg text-muted-foreground">
            A composable, themeable and customizable sidebar component for navigation.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A basic sidebar with navigation items.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="flex h-[400px] border rounded-lg overflow-hidden">
                        <Sidebar>
                            <SidebarHeader>
                                <span class="font-semibold">Acme Inc</span>
                            </SidebarHeader>
                            <SidebarContent>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#" Active="true">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        </Icon>
                                        <ChildContent>Dashboard</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                        </Icon>
                                        <ChildContent>Users</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </Icon>
                                        <ChildContent>Settings</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarContent>
                            <SidebarFooter>
                                <div class="text-xs text-muted-foreground">v1.0.0</div>
                            </SidebarFooter>
                        </Sidebar>
                        <div class="flex-1 p-6">
                            <h2 class="text-xl font-semibold">Main Content</h2>
                            <p class="text-muted-foreground mt-2">Your page content goes here.</p>
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Collapsible" Description="A sidebar that can be collapsed to show only icons.">
            <ComponentExample Code="@CollapsibleCode">
                <Preview>
                    <div class="flex h-[400px] border rounded-lg overflow-hidden">
                        <Sidebar Collapsible="true" Collapsed="@sidebarCollapsed" CollapsedChanged="v => sidebarCollapsed = v">
                            <SidebarHeader>
                                <SidebarTrigger />
                                @if (!sidebarCollapsed)
                                {
                                    <span class="font-semibold">Acme Inc</span>
                                }
                            </SidebarHeader>
                            <SidebarContent>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#" Active="true">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        </Icon>
                                        <ChildContent>Dashboard</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                        </Icon>
                                        <ChildContent>Users</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#" Badge="3">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                                        </Icon>
                                        <ChildContent>Notifications</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarContent>
                        </Sidebar>
                        <div class="flex-1 p-6">
                            <h2 class="text-xl font-semibold">Main Content</h2>
                            <p class="text-muted-foreground mt-2">Click the toggle button to collapse/expand the sidebar.</p>
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Groups" Description="Organize menu items into groups with labels.">
            <ComponentExample Code="@GroupsCode">
                <Preview>
                    <div class="flex h-[450px] border rounded-lg overflow-hidden">
                        <Sidebar>
                            <SidebarHeader>
                                <span class="font-semibold">My App</span>
                            </SidebarHeader>
                            <SidebarContent>
                                <SidebarGroup>Platform</SidebarGroup>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#" Active="true">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                        </Icon>
                                        <ChildContent>Dashboard</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
                                        </Icon>
                                        <ChildContent>Analytics</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                                
                                <SidebarGroup>Settings</SidebarGroup>
                                <SidebarMenu>
                                    <SidebarMenuItem Href="#">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        </Icon>
                                        <ChildContent>Profile</ChildContent>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem Href="#">
                                        <Icon>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </Icon>
                                        <ChildContent>Preferences</ChildContent>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarContent>
                        </Sidebar>
                        <div class="flex-1 p-6">
                            <h2 class="text-xl font-semibold">Main Content</h2>
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool sidebarCollapsed;

    private const string BasicCode = @"<Sidebar>
    <SidebarHeader>
        <span class=""font-semibold"">Acme Inc</span>
    </SidebarHeader>
    <SidebarContent>
        <SidebarMenu>
            <SidebarMenuItem Href=""/"" Active=""true"">
                <Icon>🏠</Icon>
                Dashboard
            </SidebarMenuItem>
            <SidebarMenuItem Href=""/users"">
                <Icon>👤</Icon>
                Users
            </SidebarMenuItem>
        </SidebarMenu>
    </SidebarContent>
    <SidebarFooter>
        <div class=""text-xs text-muted-foreground"">v1.0.0</div>
    </SidebarFooter>
</Sidebar>";

    private const string CollapsibleCode = @"<Sidebar Collapsible=""true"" @bind-Collapsed=""sidebarCollapsed"">
    <SidebarHeader>
        <SidebarTrigger />
        @if (!sidebarCollapsed)
        {
            <span class=""font-semibold"">Acme Inc</span>
        }
    </SidebarHeader>
    <SidebarContent>
        <SidebarMenu>
            <SidebarMenuItem Href=""/"" Active=""true"">
                <Icon>🏠</Icon>
                Dashboard
            </SidebarMenuItem>
            <SidebarMenuItem Href=""/notifications"" Badge=""3"">
                <Icon>🔔</Icon>
                Notifications
            </SidebarMenuItem>
        </SidebarMenu>
    </SidebarContent>
</Sidebar>

@code {
    private bool sidebarCollapsed;
}";

    private const string GroupsCode = @"<Sidebar>
    <SidebarHeader>
        <span class=""font-semibold"">My App</span>
    </SidebarHeader>
    <SidebarContent>
        <SidebarGroup>Platform</SidebarGroup>
        <SidebarMenu>
            <SidebarMenuItem Href=""/"" Active=""true"">
                Dashboard
            </SidebarMenuItem>
            <SidebarMenuItem Href=""/analytics"">
                Analytics
            </SidebarMenuItem>
        </SidebarMenu>
        
        <SidebarGroup>Settings</SidebarGroup>
        <SidebarMenu>
            <SidebarMenuItem Href=""/profile"">
                Profile
            </SidebarMenuItem>
        </SidebarMenu>
    </SidebarContent>
</Sidebar>";
}
