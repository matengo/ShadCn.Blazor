@page "/components/datepicker"
@using ShadCn.Blazor.Docs.Shared

<PageTitle>Date Picker - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Date Picker</h1>
        <p class="text-lg text-muted-foreground">
            A date picker component with a button trigger and calendar popup.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A simple date picker with popover calendar.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <DatePicker SelectedDate="@selectedDate" SelectedDateChanged="v => selectedDate = v" />
                    @if (selectedDate.HasValue)
                    {
                        <p class="mt-4 text-sm text-muted-foreground">
                            You selected: @selectedDate.Value.ToString("dddd, MMMM d, yyyy")
                        </p>
                    }
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Custom Placeholder" Description="Customize the placeholder text.">
            <ComponentExample Code="@PlaceholderCode">
                <Preview>
                    <DatePicker SelectedDate="@placeholderDate" 
                                SelectedDateChanged="v => placeholderDate = v"
                                Placeholder="Select your birthday" />
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Form" Description="Using DatePicker in a form context.">
            <ComponentExample Code="@FormCode">
                <Preview>
                    <Card Class="max-w-md">
                        <CardHeader>
                            <CardTitle>Book an Appointment</CardTitle>
                            <CardDescription>Choose a date for your appointment.</CardDescription>
                        </CardHeader>
                        <CardContent>
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <Label>Name</Label>
                                    <Input Placeholder="Enter your name" />
                                </div>
                                <div class="space-y-2">
                                    <Label>Appointment Date</Label>
                                    <DatePicker SelectedDate="@appointmentDate" 
                                                SelectedDateChanged="v => appointmentDate = v"
                                                MinDate="@DateTime.Today"
                                                Placeholder="Select a date" />
                                </div>
                            </div>
                        </CardContent>
                        <CardFooter>
                            <Button Class="w-full">Book Appointment</Button>
                        </CardFooter>
                    </Card>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Date Constraints" Description="Restrict selectable dates.">
            <ComponentExample Code="@ConstraintCode">
                <Preview>
                    <div class="space-y-4">
                        <div>
                            <Label Class="mb-2 block">Future dates only</Label>
                            <DatePicker SelectedDate="@futureDate" 
                                        SelectedDateChanged="v => futureDate = v"
                                        MinDate="@DateTime.Today.AddDays(1)"
                                        Placeholder="Select a future date" />
                        </div>
                        <div>
                            <Label Class="mb-2 block">Past dates only</Label>
                            <DatePicker SelectedDate="@pastDate" 
                                        SelectedDateChanged="v => pastDate = v"
                                        MaxDate="@DateTime.Today.AddDays(-1)"
                                        Placeholder="Select a past date" />
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private DateTime? selectedDate;
    private DateTime? placeholderDate;
    private DateTime? appointmentDate;
    private DateTime? futureDate;
    private DateTime? pastDate;

    private const string BasicCode = @"<DatePicker @bind-SelectedDate=""selectedDate"" />

@code {
    private DateTime? selectedDate;
}";

    private const string PlaceholderCode = @"<DatePicker @bind-SelectedDate=""selectedDate""
            Placeholder=""Select your birthday"" />";

    private const string FormCode = @"<Card>
    <CardHeader>
        <CardTitle>Book an Appointment</CardTitle>
    </CardHeader>
    <CardContent>
        <div class=""space-y-4"">
            <div class=""space-y-2"">
                <Label>Name</Label>
                <Input Placeholder=""Enter your name"" />
            </div>
            <div class=""space-y-2"">
                <Label>Appointment Date</Label>
                <DatePicker @bind-SelectedDate=""appointmentDate""
                            MinDate=""@DateTime.Today"" />
            </div>
        </div>
    </CardContent>
    <CardFooter>
        <Button>Book Appointment</Button>
    </CardFooter>
</Card>";

    private const string ConstraintCode = @"<DatePicker @bind-SelectedDate=""futureDate""
            MinDate=""@DateTime.Today.AddDays(1)""
            Placeholder=""Select a future date"" />

<DatePicker @bind-SelectedDate=""pastDate""
            MaxDate=""@DateTime.Today.AddDays(-1)""
            Placeholder=""Select a past date"" />";
}
