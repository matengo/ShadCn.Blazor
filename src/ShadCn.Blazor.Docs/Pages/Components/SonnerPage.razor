@page "/components/sonner"
@using ShadCn.Blazor.Docs.Shared
@inject ISonnerService SonnerService

<PageTitle>Sonner - ShadCn.Blazor</PageTitle>

<Sonner Position="@_position" />

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Sonner</h1>
        <p class="text-lg text-muted-foreground">
            Toast notifications powered by the Sonner service. Place the <code>&lt;Sonner /&gt;</code> component once in your layout
            and use the injected <code>ISonnerService</code> to trigger toasts from anywhere.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="Trigger a toast notification from anywhere via DI.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="flex flex-wrap gap-4">
                        <Button OnClick="ShowDefault">Show toast</Button>
                        <Button Variant="ButtonVariant.Outline" OnClick="ShowDestructive">Destructive</Button>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Persistent" Description="Set duration to 0 to keep a toast visible until dismissed.">
            <ComponentExample Code="@PersistentCode">
                <Preview>
                    <Button Variant="ButtonVariant.Secondary" OnClick="ShowPersistent">Show persistent</Button>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Position" Description="Configure where toasts appear on screen. The default is bottom-right.">
            <ComponentExample Code="@PositionCode">
                <Preview>
                    <div class="flex flex-col gap-4">
                        <div class="grid grid-cols-3 gap-2 max-w-sm">
                            <Button Variant="@GetVariant(SonnerPosition.TopLeft)" OnClick="(MouseEventArgs _) => SetPosition(SonnerPosition.TopLeft)" class="text-xs">Top Left</Button>
                            <Button Variant="@GetVariant(SonnerPosition.TopCenter)" OnClick="(MouseEventArgs _) => SetPosition(SonnerPosition.TopCenter)" class="text-xs">Top Center</Button>
                            <Button Variant="@GetVariant(SonnerPosition.TopRight)" OnClick="(MouseEventArgs _) => SetPosition(SonnerPosition.TopRight)" class="text-xs">Top Right</Button>
                            <Button Variant="@GetVariant(SonnerPosition.BottomLeft)" OnClick="(MouseEventArgs _) => SetPosition(SonnerPosition.BottomLeft)" class="text-xs">Bottom Left</Button>
                            <Button Variant="@GetVariant(SonnerPosition.BottomCenter)" OnClick="(MouseEventArgs _) => SetPosition(SonnerPosition.BottomCenter)" class="text-xs">Bottom Center</Button>
                            <Button Variant="@GetVariant(SonnerPosition.BottomRight)" OnClick="(MouseEventArgs _) => SetPosition(SonnerPosition.BottomRight)" class="text-xs">Bottom Right</Button>
                        </div>
                        <Button OnClick="ShowDefault" class="max-w-xs">Show toast</Button>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private SonnerPosition _position = SonnerPosition.BottomRight;

    private void ShowDefault(MouseEventArgs _)
    {
        SonnerService.Show("Scheduled", "Friday, February 10 at 5:57 PM.");
    }

    private void ShowDestructive(MouseEventArgs _)
    {
        SonnerService.Show("Uh oh!", "Something went wrong.", SonnerToastVariant.Destructive);
    }

    private void ShowPersistent(MouseEventArgs _)
    {
        SonnerService.Show("Uploading...", "This toast will stay until dismissed.", duration: 0);
    }

    private void SetPosition(SonnerPosition position)
    {
        SonnerService.DismissAll();
        _position = position;
    }

    private ButtonVariant GetVariant(SonnerPosition position)
        => _position == position ? ButtonVariant.Default : ButtonVariant.Outline;

    private const string BasicCode = @"@inject ISonnerService SonnerService

<Sonner />

<Button OnClick=""ShowDefault"">Show toast</Button>
<Button Variant=""ButtonVariant.Outline"" OnClick=""ShowDestructive"">Destructive</Button>

@code {
    private void ShowDefault(MouseEventArgs _)
    {
        SonnerService.Show(""Scheduled"", ""Friday, February 10 at 5:57 PM."");
    }

    private void ShowDestructive(MouseEventArgs _)
    {
        SonnerService.Show(""Uh oh!"", ""Something went wrong."", SonnerToastVariant.Destructive);
    }
}";

    private const string PersistentCode = @"<Sonner />

<Button OnClick=""ShowPersistent"">Show persistent</Button>

@code {
    private void ShowPersistent(MouseEventArgs _)
    {
        SonnerService.Show(""Uploading..."", ""This toast will stay until dismissed."", duration: 0);
    }
}";

    private const string PositionCode = @"<Sonner Position=""SonnerPosition.TopRight"" />

@* Available positions: *@
@* SonnerPosition.TopLeft *@
@* SonnerPosition.TopCenter *@
@* SonnerPosition.TopRight *@
@* SonnerPosition.BottomLeft (default) *@
@* SonnerPosition.BottomCenter *@
@* SonnerPosition.BottomRight *@";
}
