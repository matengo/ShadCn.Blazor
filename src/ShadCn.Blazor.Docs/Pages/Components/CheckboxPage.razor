@page "/components/checkbox"
@using ShadCn.Blazor.Docs.Shared

<PageTitle>Checkbox - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Checkbox</h1>
        <p class="text-lg text-muted-foreground">
            A control that allows the user to toggle between checked and not checked.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A basic checkbox with two-way binding.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="flex items-center space-x-2">
                        <Checkbox Checked="@isChecked" CheckedChanged="v => isChecked = v" />
                        <Label>Accept terms and conditions</Label>
                    </div>
                    <p class="text-sm text-muted-foreground mt-2">Checked: @isChecked</p>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Label" Description="Combine with Label component for accessibility.">
            <ComponentExample Code="@WithLabelCode">
                <Preview>
                    <div class="space-y-4">
                        <div class="flex items-center space-x-2">
                            <Checkbox Checked="@option1" CheckedChanged="v => option1 = v" />
                            <Label>Email notifications</Label>
                        </div>
                        <div class="flex items-center space-x-2">
                            <Checkbox Checked="@option2" CheckedChanged="v => option2 = v" />
                            <Label>SMS notifications</Label>
                        </div>
                        <div class="flex items-center space-x-2">
                            <Checkbox Checked="@option3" CheckedChanged="v => option3 = v" />
                            <Label>Push notifications</Label>
                        </div>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Disabled" Description="Checkbox can be disabled.">
            <ComponentExample Code="@DisabledCode">
                <Preview>
                    <div class="flex items-center space-x-2">
                        <Checkbox Checked="true" Disabled="true" />
                        <Label>Disabled (checked)</Label>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private bool isChecked = false;
    private bool option1 = true;
    private bool option2 = false;
    private bool option3 = true;

    private const string BasicCode = @"<div class=""flex items-center space-x-2"">
    <Checkbox @bind-Checked=""isChecked"" />
    <Label>Accept terms and conditions</Label>
</div>

@code {
    private bool isChecked = false;
}";

    private const string WithLabelCode = @"<div class=""flex items-center space-x-2"">
    <Checkbox @bind-Checked=""emailNotifications"" />
    <Label>Email notifications</Label>
</div>";

    private const string DisabledCode = @"<Checkbox Checked=""true"" Disabled=""true"" />";
}
