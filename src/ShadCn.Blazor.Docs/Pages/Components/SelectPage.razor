@page "/components/select"
@using ShadCn.Blazor.Docs.Shared

<PageTitle>Select - ShadCn.Blazor</PageTitle>

<div class="space-y-8">
    <div class="space-y-4">
        <h1 class="text-3xl font-bold">Select</h1>
        <p class="text-lg text-muted-foreground">
            Displays a list of options for the user to pick from.
        </p>
    </div>

    <Separator />

    <div class="space-y-8">
        <ExampleSection Title="Basic" Description="A basic select dropdown.">
            <ComponentExample Code="@BasicCode">
                <Preview>
                    <div class="w-full max-w-sm">
                        <Select Value="@selectedFruit" ValueChanged="v => selectedFruit = v" Placeholder="Select a fruit">
                            <option value="apple">Apple</option>
                            <option value="banana">Banana</option>
                            <option value="orange">Orange</option>
                            <option value="grape">Grape</option>
                        </Select>
                        <p class="text-sm text-muted-foreground mt-2">Selected: @(string.IsNullOrEmpty(selectedFruit) ? "None" : selectedFruit)</p>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="With Label" Description="Select with a label.">
            <ComponentExample Code="@WithLabelCode">
                <Preview>
                    <div class="w-full max-w-sm space-y-2">
                        <Label For="framework">Framework</Label>
                        <Select id="framework" Value="@selectedFramework" ValueChanged="v => selectedFramework = v" Placeholder="Select a framework">
                            <option value="blazor">Blazor</option>
                            <option value="react">React</option>
                            <option value="vue">Vue</option>
                            <option value="angular">Angular</option>
                            <option value="svelte">Svelte</option>
                        </Select>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>

        <ExampleSection Title="Disabled" Description="Disabled select.">
            <ComponentExample Code="@DisabledCode">
                <Preview>
                    <div class="w-full max-w-sm">
                        <Select Placeholder="This select is disabled" Disabled="true">
                            <option value="1">Option 1</option>
                            <option value="2">Option 2</option>
                        </Select>
                    </div>
                </Preview>
            </ComponentExample>
        </ExampleSection>
    </div>
</div>

@code {
    private string selectedFruit = "";
    private string selectedFramework = "";

    private const string BasicCode = @"<Select @bind-Value=""selectedFruit"" Placeholder=""Select a fruit"">
    <option value=""apple"">Apple</option>
    <option value=""banana"">Banana</option>
    <option value=""orange"">Orange</option>
</Select>

@code {
    private string selectedFruit = """";
}";

    private const string WithLabelCode = @"<Label For=""framework"">Framework</Label>
<Select id=""framework"" @bind-Value=""selectedFramework"">
    <option value=""blazor"">Blazor</option>
    <option value=""react"">React</option>
</Select>";

    private const string DisabledCode = @"<Select Placeholder=""Disabled"" Disabled=""true"">
    <option value=""1"">Option 1</option>
</Select>";
}
