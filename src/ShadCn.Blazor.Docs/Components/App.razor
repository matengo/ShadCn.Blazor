<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["_content/ShadCn.Blazor.Theme.Default/theme.css"]" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="icon" type="image/png" href="favicon.png" />
    @* <link href="ShadCn.Blazor.Docs.Client.styles.css" rel="stylesheet" /> *@
    <meta name="author" content="ShadCn.Blazor" />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:site_name" content="ShadCn.Blazor" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:site" content="ShadCn.Blazor" />
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveWebAssembly" />
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "SoftwareSourceCode",
        "name": "ShadCn.Blazor",
        "description": "A Blazor component library inspired by shadcn/ui. Accessible, customizable, and open source UI components for Blazor.",
        "programmingLanguage": "C#",
        "runtimePlatform": ".NET",
        "license": "https://opensource.org/licenses/MIT",
        "codeRepository": "https://github.com/matengo/ShadCn.Blazor",
        "url": "https://www.shadcn-blazor.dev"
    }
    </script>
</head>

<body class="min-h-screen bg-background font-sans antialiased">
    <Routes @rendermode="InteractiveWebAssembly" />
    <script>
        (function () {
            var theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();

        window.themeInterop = {
            toggle: function () {
                var isDark = document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                return isDark;
            },
            isDark: function () {
                return document.documentElement.classList.contains('dark');
            }
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
