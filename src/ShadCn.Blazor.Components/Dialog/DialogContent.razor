@namespace ShadCn.Blazor.Components.Dialog
@using ShadCn.Blazor.Primitives.Utilities

@if (Dialog?.Open == true || IsExiting)
{
    <div class="@ContainerClass" style="z-index: @ZIndex">
        @* Overlay with animation *@
        <div class="@OverlayClass" @onclick="HandleOverlayClick"></div>
        
        @* Content with animation *@
        <div class="@ComputedClass" role="dialog" aria-modal="true" @attributes="AdditionalAttributes">
            @ChildContent
            <button type="button" 
                    class="absolute right-4 top-4 rounded-sm opacity-70 ring-offset-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 disabled:pointer-events-none"
                    @onclick="HandleClose">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                </svg>
                <span class="sr-only">Close</span>
            </button>
        </div>
    </div>
}

@code {
    [CascadingParameter] public Dialog? Dialog { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public DialogSize Size { get; set; } = DialogSize.Default;
    [Parameter] public int ZIndex { get; set; } = 50;
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsExiting => Dialog?.Closing ?? false;
    private bool IsFullScreen => Size == DialogSize.Full;

    private string ContainerClass => IsFullScreen
        ? "fixed inset-0"
        : "fixed inset-0 flex items-center justify-center";

    private string OverlayClass => IsExiting
        ? "fixed inset-0 bg-black/40 animate-out fade-out-0 duration-200"
        : "fixed inset-0 bg-black/40 animate-in fade-in-0 duration-200";

    private string SizeClass => Size switch
    {
        DialogSize.Sm => "max-w-sm",
        DialogSize.Md => "max-w-md",
        DialogSize.Lg => "max-w-lg",
        DialogSize.Xl => "max-w-xl",
        DialogSize.Max2xl => "max-w-2xl",
        DialogSize.Max3xl => "max-w-3xl",
        DialogSize.Max4xl => "max-w-4xl",
        DialogSize.Max5xl => "max-w-5xl",
        DialogSize.Max6xl => "max-w-6xl",
        DialogSize.Max7xl => "max-w-7xl",
        DialogSize.Full => "",
        _ => "max-w-lg"
    };

    private string ComputedClass
    {
        get
        {
            if (IsFullScreen)
            {
                var fullBase = IsExiting
                    ? "relative flex flex-col w-full h-full border bg-background shadow-lg animate-out fade-out-0 zoom-out-95 duration-200"
                    : "relative flex flex-col w-full h-full border bg-background shadow-lg animate-in fade-in-0 zoom-in-95 duration-200";
                return new ClassBuilder(fullBase).Add(Class).Build();
            }

            var baseClass = IsExiting
                ? "relative flex flex-col w-full max-h-[85vh] border bg-background shadow-lg sm:rounded-lg animate-out fade-out-0 zoom-out-95 duration-200"
                : "relative flex flex-col w-full max-h-[85vh] border bg-background shadow-lg sm:rounded-lg animate-in fade-in-0 zoom-in-95 duration-200";
            return new ClassBuilder(baseClass).Add(SizeClass).Add(Class).Build();
        }
    }

    private async Task HandleOverlayClick()
    {
        if (Dialog != null)
        {
            await Dialog.SetOpen(false);
        }
    }

    private async Task HandleClose()
    {
        if (Dialog != null)
        {
            await Dialog.SetOpen(false);
        }
    }
}
