@namespace ShadCn.Blazor.Components.Sheet

<CascadingValue Value="this">
    @ChildContent
</CascadingValue>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Open { get; set; }
    [Parameter] public bool IsClosing { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    private bool _internalIsClosing;

    public bool Closing => IsClosing || _internalIsClosing;

    internal async Task SetOpen(bool open)
    {
        if (!open && Open && !Closing)
        {
            _internalIsClosing = true;
            StateHasChanged();
            await Task.Delay(300);
            _internalIsClosing = false;
        }

        Open = open;
        await OpenChanged.InvokeAsync(Open);
    }
}
