@namespace ShadCn.Blazor.Components.Sheet
@using ShadCn.Blazor.Components
@inject SheetService Service
@implements IDisposable

@if (Service.Sheets.Any())
{
    var index = 0;
    @foreach (var sheet in Service.Sheets)
    {
        var zIndex = 50 + (index * 10);
        <Sheet @key="sheet.Id" Open="true" IsClosing="@sheet.IsClosing" OpenChanged="@((bool open) => { if(!open) Service.FinalizeClose(sheet.Id, null); })">
            <SheetContent Side="@sheet.Options.Side" Class="@sheet.Options.Class" ZIndex="@zIndex">
                <CascadingValue Value="new SheetContext(sheet, Service)" IsFixed="true">
                    @if (sheet.ComponentType != null)
                    {
                        <DynamicComponent Type="sheet.ComponentType" Parameters="sheet.Parameters" />
                    }
                    else if (sheet.Content != null)
                    {
                        @sheet.Content
                    }
                </CascadingValue>
            </SheetContent>
        </Sheet>
        index++;
    }
}

@code {
    protected override void OnInitialized()
    {
        Service.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Service.OnChange -= StateHasChanged;
    }
}
