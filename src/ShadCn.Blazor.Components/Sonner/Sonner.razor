@namespace ShadCn.Blazor.Components
@using ShadCn.Blazor.Primitives.Utilities
@implements IDisposable
@inject ISonnerService SonnerService

@if (SonnerService.Toasts.Count > 0)
{
    <div class="@ContainerClass" aria-live="polite">
        @{
            var allToasts = SonnerService.Toasts;
            var count = allToasts.Count;
            var visible = System.Math.Min(count, MaxVisible + 2);
        }
        @for (var i = 0; i < visible; i++)
        {
            var toast = allToasts[count - 1 - i];
            var index = i;
            var isFront = index < MaxVisible;

            <div @key="toast.Id" class="@GetToastClass(toast)" style="@GetItemStyle(index)" role="status">
                @if (ToastTemplate != null)
                {
                    @ToastTemplate(toast)
                }
                else
                {
                    <div class="grid gap-1">
                        <div class="text-sm font-semibold">@toast.Title</div>
                        @if (!string.IsNullOrWhiteSpace(toast.Description))
                        {
                            <div class="@GetDescriptionClass(toast)">@toast.Description</div>
                        }
                    </div>
                    @if (toast.Dismissible && isFront)
                    {
                        <button type="button"
                                class="@GetDismissClass(toast)"
                                @onclick="() => Dismiss(toast.Id)">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6 6 18" />
                                <path d="M6 6 18 18" />
                            </svg>
                        </button>
                    }
                }
            </div>
        }
    </div>
}

@code {
    /// <summary>How many toasts are fully visible before stacking begins.</summary>
    [Parameter] public int MaxVisible { get; set; } = 3;
    [Parameter] public SonnerPosition Position { get; set; } = SonnerPosition.BottomRight;
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment<SonnerToast>? ToastTemplate { get; set; }

    // Estimated toast height (rem). Real Sonner measures via JS; we use a fixed estimate.
    private const double ToastHeightRem = 4.75;
    // Gap between visible toasts (rem).
    private const double GapRem = 0.5;

    protected override void OnInitialized()
    {
        SonnerService.OnChange += HandleChange;
    }

    private void HandleChange()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SonnerService.OnChange -= HandleChange;
    }

    private void Dismiss(Guid id) => SonnerService.Dismiss(id);

    private bool IsTopPosition => Position is SonnerPosition.TopLeft or SonnerPosition.TopCenter or SonnerPosition.TopRight;

    /// <summary>
    /// Each toast is absolutely positioned at the edge and offset via translateY.
    /// index 0 = newest (closest to edge), index N = older (further from edge).
    /// Behind toasts (index >= MaxVisible) also scale down and fade.
    /// </summary>
    private string GetItemStyle(int index)
    {
        var inv = System.Globalization.CultureInfo.InvariantCulture;
        var offset = GapRem + index * (ToastHeightRem + GapRem);
        // Bottom: translate up (negative Y). Top: translate down (positive Y).
        var ty = IsTopPosition ? offset : -offset;
        var edge = IsTopPosition ? "top: 0;" : "bottom: 0;";
        var animName = IsTopPosition ? "sonner-enter-from-top" : "sonner-enter-from-bottom";
        var anim = $"animation: {animName} 300ms ease-out;";

        if (index < MaxVisible)
        {
            return $"position: absolute; {edge} left: 0; right: 0; " +
                   $"z-index: {100 - index}; " +
                   $"transform: translateY({ty.ToString("F2", inv)}rem); " +
                   $"transition: transform 300ms ease, opacity 300ms ease; {anim}";
        }

        // Behind toast — scaled down, faded, non-interactive
        var behind = index - MaxVisible; // 0 or 1
        var scale = 1.0 - (behind + 1) * 0.05; // 0.95, 0.90
        var opacity = System.Math.Max(0.0, 0.6 - behind * 0.6); // 0.6, 0.0

        return $"position: absolute; {edge} left: 0; right: 0; " +
               $"z-index: {100 - index}; " +
               $"transform: translateY({ty.ToString("F2", inv)}rem) scale({scale.ToString("F2", inv)}); " +
               $"opacity: {opacity.ToString("F2", inv)}; " +
               $"pointer-events: none; " +
               $"transition: transform 300ms ease, opacity 300ms ease; {anim}";
    }

    private string ContainerClass => new ClassBuilder(
            "fixed z-50 w-full max-w-sm p-4 pointer-events-none")
        .Add(GetPositionClasses())
        .Add(Class)
        .Build();

    private string GetPositionClasses()
        => Position switch
        {
            SonnerPosition.TopLeft => "top-2 left-2",
            SonnerPosition.TopCenter => "top-2 left-1/2 -translate-x-1/2",
            SonnerPosition.TopRight => "top-2 right-2",
            SonnerPosition.BottomLeft => "bottom-2 left-2",
            SonnerPosition.BottomCenter => "bottom-2 left-1/2 -translate-x-1/2",
            SonnerPosition.BottomRight => "bottom-2 right-2",
            _ => "bottom-2 right-2"
        };

    private string GetToastClass(SonnerToast toast)
        => new ClassBuilder(
            "pointer-events-auto flex w-full items-start gap-3 rounded-md border p-4 shadow-lg")
            .Add("bg-background text-foreground", toast.Variant != SonnerToastVariant.Destructive)
            .Add("bg-destructive text-destructive-foreground border-destructive", toast.Variant == SonnerToastVariant.Destructive)
            .Build();

    private string GetDescriptionClass(SonnerToast toast)
        => new ClassBuilder("text-sm")
            .Add("text-muted-foreground", toast.Variant != SonnerToastVariant.Destructive)
            .Add("text-destructive-foreground", toast.Variant == SonnerToastVariant.Destructive)
            .Build();

    private string GetDismissClass(SonnerToast toast)
        => new ClassBuilder(
            "ml-auto inline-flex h-7 w-7 items-center justify-center rounded-md transition-colors " +
            "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2")
            .Add("text-muted-foreground hover:text-foreground", toast.Variant != SonnerToastVariant.Destructive)
            .Add("text-destructive-foreground hover:text-destructive-foreground", toast.Variant == SonnerToastVariant.Destructive)
            .Build();
}
