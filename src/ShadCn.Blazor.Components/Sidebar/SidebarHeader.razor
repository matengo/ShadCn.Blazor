@namespace ShadCn.Blazor.Components
@using ShadCn.Blazor.Primitives.Utilities

<div class="@ComputedClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [CascadingParameter] public Sidebar? Sidebar { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => new ClassBuilder(
        "flex h-14 items-center border-b px-4")
        .Add(Sidebar?.Collapsed == true ? "justify-center" : "justify-between")
        .Add(Class)
        .Build();
}
