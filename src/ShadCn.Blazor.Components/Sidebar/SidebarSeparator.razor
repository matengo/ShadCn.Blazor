@namespace ShadCn.Blazor.Components
@using ShadCn.Blazor.Primitives.Utilities

<hr class="@ComputedClass" @attributes="AdditionalAttributes" />

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => new ClassBuilder(
        "my-2 border-sidebar-border")
        .Add(Class)
        .Build();
}
