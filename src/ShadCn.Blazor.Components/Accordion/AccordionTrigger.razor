@namespace ShadCn.Blazor.Components.Accordion
@using ShadCn.Blazor.Primitives.Utilities

<h3 class="flex">
    <button type="button"
            class="@ComputedClass"
            aria-expanded="@IsOpen.ToString().ToLower()"
            disabled="@IsDisabled"
            @onclick="HandleClick"
            @attributes="AdditionalAttributes">
        @ChildContent
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="@ChevronClass">
            <path d="m6 9 6 6 6-6"/>
        </svg>
    </button>
</h3>

@code {
    [CascadingParameter] public AccordionItem? Item { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsOpen => Item?.IsOpen ?? false;
    private bool IsDisabled => Item?.Disabled ?? false;

    private void HandleClick()
    {
        Item?.Toggle();
    }

    private string ChevronClass => new ClassBuilder(
        "h-4 w-4 shrink-0 transition-transform duration-200")
        .Add(IsOpen ? "rotate-180" : "")
        .Build();

    private string ComputedClass => new ClassBuilder(
        "flex flex-1 items-center justify-between py-4 font-medium transition-all hover:underline text-left " +
        "disabled:pointer-events-none disabled:opacity-50")
        .Add(Class)
        .Build();
}
