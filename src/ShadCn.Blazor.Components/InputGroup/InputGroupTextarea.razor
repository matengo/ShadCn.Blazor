@namespace ShadCn.Blazor.Components.InputGroup

<textarea @attributes="AdditionalAttributes"
          data-slot="input-group-control"
          class="@ComputedClass"
          placeholder="@Placeholder"
          rows="@Rows"
          disabled="@Disabled"
          value="@Value"
          @oninput="HandleInput"></textarea>

@code {
    private static readonly string BaseClasses =
        "flex-1 resize-none bg-transparent px-3 py-2 text-sm outline-none " +
        "placeholder:text-muted-foreground " +
        "disabled:cursor-not-allowed";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public int Rows { get; set; } = 3;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => string.IsNullOrEmpty(Class)
        ? BaseClasses
        : $"{BaseClasses} {Class}";

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}
