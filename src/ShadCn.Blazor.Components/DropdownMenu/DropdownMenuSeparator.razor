@namespace ShadCn.Blazor.Components.DropdownMenu
@using ShadCn.Blazor.Primitives.Utilities

<div role="separator" class="@ComputedClass" @attributes="AdditionalAttributes"></div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => new ClassBuilder("-mx-1 my-1 h-px bg-muted")
        .Add(Class)
        .Build();
}
