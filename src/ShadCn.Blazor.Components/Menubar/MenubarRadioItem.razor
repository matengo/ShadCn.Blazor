@namespace ShadCn.Blazor.Components.Menubar

<DropdownMenuRadioItem Value="Value" Disabled="Disabled" Class="@Class">
    @ChildContent
</DropdownMenuRadioItem>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Class { get; set; }
}
