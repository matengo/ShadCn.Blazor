@namespace ShadCn.Blazor.Components.Alert

<div @attributes="AdditionalAttributes" class="@ComputedClass">
    @ChildContent
</div>

@code {
    private static readonly string BaseClasses = "text-sm [&_p]:leading-relaxed";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => string.IsNullOrEmpty(Class) 
        ? BaseClasses 
        : $"{BaseClasses} {Class}";
}
