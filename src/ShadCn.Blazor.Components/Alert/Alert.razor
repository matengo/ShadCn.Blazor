@namespace ShadCn.Blazor.Components.Alert

<div @attributes="AdditionalAttributes" role="alert" class="@ComputedClass">
    @ChildContent
</div>

@code {
    [Parameter]
    public AlertVariant Variant { get; set; } = AlertVariant.Default;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => AlertVariants.GetClasses(Variant, Class);
}
