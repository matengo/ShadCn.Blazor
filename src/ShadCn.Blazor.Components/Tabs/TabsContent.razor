@namespace ShadCn.Blazor.Components
@using ShadCn.Blazor.Primitives.Utilities

@if (IsSelected)
{
    <div class="@ComputedClass" role="tabpanel" @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@code {
    [CascadingParameter] public Tabs? Parent { get; set; }
    
    [Parameter, EditorRequired] public string Value { get; set; } = default!;
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsSelected => Parent?.SelectedValue == Value;

    private string ComputedClass => new ClassBuilder(
        "mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2")
        .Add(Class)
        .Build();
}
