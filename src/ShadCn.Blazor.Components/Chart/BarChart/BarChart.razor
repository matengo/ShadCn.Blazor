@namespace ShadCn.Blazor.Components.Chart
@using ShadCn.Blazor.Components.Chart.Internal
@using ShadCn.Blazor.Primitives.Utilities
@using System.Globalization

@if (context != null)
{
    <svg viewBox="@ViewBox"
         class="@ComputedClass"
         preserveAspectRatio="xMidYMid meet"
         @onmousemove="HandleMouseMove"
         @onmouseleave="HandleMouseLeave"
         @attributes="AdditionalAttributes">
        @ChildContent
    </svg>
}

@code {
    [CascadingParameter]
    private ChartContext? context { get; set; }

    /// <summary>
    /// Chart data as a list of objects (POCO or Dictionary).
    /// </summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<object> Data { get; set; } = [];

    /// <summary>
    /// Chart viewBox width (internal coordinate system).
    /// </summary>
    [Parameter]
    public double Width { get; set; } = 500;

    /// <summary>
    /// Chart viewBox height (internal coordinate system).
    /// </summary>
    [Parameter]
    public double Height { get; set; } = 300;

    /// <summary>
    /// Chart margins.
    /// </summary>
    [Parameter]
    public ChartMargin? Margin { get; set; }

    /// <summary>
    /// Bar layout direction.
    /// </summary>
    [Parameter]
    public BarLayout Layout { get; set; } = BarLayout.Vertical;

    /// <summary>
    /// X-axis data key for categories.
    /// </summary>
    [Parameter]
    public string? XDataKey { get; set; }

    /// <summary>
    /// Additional CSS classes.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // Collected bar data keys
    internal List<string> BarDataKeys { get; } = [];

    private string ViewBox => $"0 0 {F(Width)} {F(Height)}";

    private string ComputedClass => new ClassBuilder("w-full h-full")
        .Add(Class)
        .Build();

    private IReadOnlyList<object>? _previousData;

    protected override void OnParametersSet()
    {
        if (context == null) return;

        if (_previousData != Data)
        {
            context.DataVersion++;
            _previousData = Data;
        }

        var margin = Margin ?? new ChartMargin();
        context.Width = Width;
        context.Height = Height;
        context.Margin = margin;
        context.Data = Data;
        context.XDataKey = XDataKey;

        BuildScales();
    }

    private void BuildScales()
    {
        if (context == null || Data.Count == 0) return;

        // Discover XDataKey from XAxis child if not set directly
        var xKey = context.XDataKey ?? XDataKey;
        if (string.IsNullOrEmpty(xKey) && Data.Count > 0)
        {
            // Use first string property as default
            xKey = "name";
        }

        // Build band scale for categories
        var categories = DataAccessor.GetAllStrings(Data, xKey!);
        context.XBandScale = new ScaleBand(categories, context.PlotLeft, context.PlotRight, 0.2, 0.1);
        context.XDataKey = xKey;

        // Compute Y domain across all numeric series in config
        double yMin = 0, yMax = 0;
        foreach (var key in context.Config.Keys)
        {
            var values = DataAccessor.GetAllDoubles(Data, key);
            foreach (var v in values)
            {
                if (v > yMax) yMax = v;
                if (v < yMin) yMin = v;
            }
        }

        var (niceMin, niceMax) = ChartMath.NiceExtent(yMin, yMax);
        // Y scale is inverted: higher values at top (lower pixel y)
        context.YScale = new ScaleLinear(niceMin, niceMax, context.PlotBottom, context.PlotTop);
    }

    private void HandleMouseMove(MouseEventArgs e)
    {
        if (context == null || context.XBandScale == null) return;

        var relX = e.OffsetX * Width / 1; // SVG coordinates
        // Find closest category index
        var categories = context.XBandScale.Domain;
        int bestIndex = -1;
        double bestDist = double.MaxValue;
        for (int i = 0; i < categories.Count; i++)
        {
            var cx = context.XBandScale.ScaleCenter(categories[i]);
            var dist = Math.Abs(relX - cx);
            if (dist < bestDist)
            {
                bestDist = dist;
                bestIndex = i;
            }
        }
        context.SetActiveIndex(bestIndex, e.OffsetX, e.OffsetY);
    }

    private void HandleMouseLeave(MouseEventArgs e)
    {
        context?.ClearActiveIndex();
    }

    private static string F(double v) => v.ToString("G6", CultureInfo.InvariantCulture);
}
