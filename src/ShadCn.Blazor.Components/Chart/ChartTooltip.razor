@namespace ShadCn.Blazor.Components.Chart

@* Registration-only component: configures tooltip on ChartContext.
   The actual tooltip HTML is rendered by ChartContainer (outside the SVG). *@

@code {
    [CascadingParameter]
    private ChartContext? context { get; set; }

    /// <summary>
    /// Custom tooltip content. If not provided, uses default ChartTooltipContent.
    /// </summary>
    [Parameter]
    public RenderFragment? Content { get; set; }

    /// <summary>
    /// Hide the tooltip label.
    /// </summary>
    [Parameter]
    public bool HideLabel { get; set; } = false;

    /// <summary>
    /// Hide the color indicator.
    /// </summary>
    [Parameter]
    public bool HideIndicator { get; set; } = false;

    /// <summary>
    /// Indicator style.
    /// </summary>
    [Parameter]
    public TooltipIndicator Indicator { get; set; } = TooltipIndicator.Dot;

    /// <summary>
    /// Config or data key to use for the label.
    /// </summary>
    [Parameter]
    public string? LabelKey { get; set; }

    /// <summary>
    /// Config or data key to use for the name.
    /// </summary>
    [Parameter]
    public string? NameKey { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        if (context == null) return;
        context.TooltipEnabled = true;
        context.TooltipHideLabel = HideLabel;
        context.TooltipHideIndicator = HideIndicator;
        context.TooltipIndicator = Indicator;
        context.TooltipLabelKey = LabelKey;
        context.TooltipNameKey = NameKey;
        context.TooltipCustomContent = Content;
        context.TooltipClass = Class;
    }
}
