@namespace ShadCn.Blazor.Components.Chart
@using ShadCn.Blazor.Primitives.Utilities
@using System.Globalization

<div class="@ComputedClass" style="@ComputedStyle" @attributes="AdditionalAttributes">
    <CascadingValue Value="Context" IsFixed="false">
        @ChildContent

        @* Tooltip rendered inside CascadingValue (for context access) but outside the SVG *@
        @if (Context.TooltipEnabled && Context.ActiveIndex >= 0 && Context.ActiveIndex < Context.Data.Count)
        {
            <div class="@TooltipClass" style="@TooltipPositionStyle">
                @if (Context.TooltipCustomContent != null)
                {
                    @Context.TooltipCustomContent
                }
                else
                {
                    <ChartTooltipContent HideLabel="Context.TooltipHideLabel"
                                         HideIndicator="Context.TooltipHideIndicator"
                                         Indicator="Context.TooltipIndicator"
                                         LabelKey="@Context.TooltipLabelKey"
                                         NameKey="@Context.TooltipNameKey" />
                }
            </div>
        }
    </CascadingValue>
</div>

@code {
    /// <summary>
    /// Chart configuration mapping data keys to labels and colors.
    /// </summary>
    [Parameter, EditorRequired]
    public ChartConfig Config { get; set; } = new();

    /// <summary>
    /// Additional CSS classes.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    internal ChartContext Context { get; set; } = new();

    private string ComputedClass => new ClassBuilder("relative")
        .Add(Class)
        .Build();

    private string ComputedStyle
    {
        get
        {
            var styles = new List<string>();
            foreach (var (key, entry) in Config)
            {
                var color = entry.Color;
                if (!string.IsNullOrEmpty(color))
                {
                    styles.Add($"--color-{key}: {color}");
                }
            }
            return string.Join("; ", styles);
        }
    }

    private string TooltipClass => new ClassBuilder(
        "absolute z-50 pointer-events-none rounded-lg border bg-background px-3 py-1.5 text-sm shadow-md")
        .Add(Context.TooltipClass)
        .Build();

    private string TooltipPositionStyle
    {
        get
        {
            var left = Context.TooltipLeftPct.ToString("F1", CultureInfo.InvariantCulture);
            var top = Context.TooltipTopPct.ToString("F1", CultureInfo.InvariantCulture);
            return $"left: {left}%; top: {top}%; transform: translateX(-50%) translateY(-100%) translateY(-8px);";
        }
    }

    protected override void OnParametersSet()
    {
        Context.Config = Config;
        Context.OnStateChanged = () => InvokeAsync(StateHasChanged);
    }
}
