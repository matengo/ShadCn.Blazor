@namespace ShadCn.Blazor.Components.AlertDialog
@using ShadCn.Blazor.Primitives.Utilities

@if (AlertDialog?.Open == true || IsExiting)
{
    <div class="fixed inset-0 flex items-center justify-center" style="z-index: @ZIndex">
        @* Overlay *@
        <div class="@OverlayClass"></div>

        @* Content — no close button, user must use Action/Cancel *@
        <div class="@ComputedClass" role="alertdialog" aria-modal="true" @attributes="AdditionalAttributes">
            @ChildContent
        </div>
    </div>
}

@code {
    [CascadingParameter] public AlertDialog? AlertDialog { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public int ZIndex { get; set; } = 50;
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsExiting => AlertDialog?.Closing ?? false;

    private string OverlayClass => IsExiting
        ? "fixed inset-0 bg-black/40 animate-out fade-out-0 duration-200"
        : "fixed inset-0 bg-black/40 animate-in fade-in-0 duration-200";

    private string ComputedClass => new ClassBuilder(
        IsExiting
            ? "relative grid w-full max-w-lg gap-4 border bg-background p-6 shadow-lg sm:rounded-lg animate-out fade-out-0 zoom-out-95 duration-200"
            : "relative grid w-full max-w-lg gap-4 border bg-background p-6 shadow-lg sm:rounded-lg animate-in fade-in-0 zoom-in-95 duration-200")
        .Add(Class)
        .Build();
}
